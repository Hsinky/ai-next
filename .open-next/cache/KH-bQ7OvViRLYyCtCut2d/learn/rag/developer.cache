d text-lg mb-3\",\"children\":\"2. 查询改写（Query Expansion）\"}],[\"$\",\"div\",null,{\"className\":\"bg-green-50 p-4 rounded-lg\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-gray-700 mb-3\",\"children\":\"对用户问题进行改写和扩展，提高召回率：\"}],[\"$\",\"div\",null,{\"className\":\"bg-white p-2 rounded border text-xs mb-2\",\"children\":[[\"$\",\"p\",null,{\"children\":\"原始问题：\\\"公司有什么产品？\\\"\"}],[\"$\",\"p\",null,{\"children\":\"改写后：\"}],[\"$\",\"p\",null,{\"children\":\"  1. \\\"公司有哪些产品？\\\"\"}],[\"$\",\"p\",null,{\"children\":\"  2. \\\"公司提供什么服务？\\\"\"}],[\"$\",\"p\",null,{\"children\":\"  3. \\\"公司的主要业务是什么？\\\"\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-sm text-gray-600\",\"children\":\"并行检索 3 个问题，合并结果\"}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"h4\",null,{\"className\":\"font-bold text-lg mb-3\",\"children\":\"3. 重排序（Reranking）\"}],[\"$\",\"div\",null,{\"className\":\"bg-orange-50 p-4 rounded-lg\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-gray-700 mb-3\",\"children\":\"对初步检索结果进行二次排序，提高准确性：\"}],[\"$\",\"div\",null,{\"className\":\"text-sm text-gray-600 mb-2\",\"children\":[\"$\",\"strong\",null,{\"children\":\"方法 1：交叉编码器（Cross-Encoder）\"}]}],[\"$\",\"p\",null,{\"className\":\"text-xs text-gray-500\",\"children\":\"使用更强的模型（如 GPT-4）对检索结果打分排序\"}],[\"$\",\"div\",null,{\"className\":\"text-sm text-gray-600 mb-2 mt-3\",\"children\":[\"$\",\"strong\",null,{\"children\":\"方法 2：LLM 评分\"}]}],[\"$\",\"div\",null,{\"className\":\"bg-white p-2 rounded border text-xs\",\"children\":[\"$\",\"p\",null,{\"children\":\"Prompt：\\\"以下哪个文档片段最相关？请按相关性排序\\\"\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"bg-blue-50 p-4 rounded-lg\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"font-semibold mb-2 text-blue-700\",\"children\":\"性能优化\"}],[\"$\",\"ul\",null,{\"className\":\"text-sm text-gray-700 space-y-1\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"• \",[\"$\",\"strong\",null,{\"children\":\"缓存\"}],\"：相同问题直接复用检索结果\"]}],[\"$\",\"li\",null,{\"children\":[\"•