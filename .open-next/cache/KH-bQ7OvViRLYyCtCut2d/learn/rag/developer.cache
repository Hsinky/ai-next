{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/(main)/layout,_N_T_/(main)/learn/layout,_N_T_/(main)/learn/[type]/layout,_N_T_/(main)/learn/[type]/[level]/layout,_N_T_/(main)/learn/[type]/[level]/page,_N_T_/learn/rag/developer"},"segmentPaths":["/_tree","/_full","/!KG1haW4p/learn/$d$type/$d$level/__PAGE__","/!KG1haW4p/learn/$d$type/$d$level","/!KG1haW4p/learn/$d$type","/!KG1haW4p/learn","/!KG1haW4p","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0.q-h669a_dqa.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.16t1db8_9y2o~.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0.6dsdn7g3rv..css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0j6kpnbwgrhei.js\"/><script src=\"/_next/static/chunks/14uv9l3-k2qh4.js\" async=\"\"></script><script src=\"/_next/static/chunks/16sk4~vc8e6sh.js\" async=\"\"></script><script src=\"/_next/static/chunks/0c9ih0_ge37cg.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-02v2juswviadt.js\" async=\"\"></script><script src=\"/_next/static/chunks/0~gz256ffq795.js\" async=\"\"></script><script src=\"/_next/static/chunks/0pk5qoo78d3co.js\" async=\"\"></script><script src=\"/_next/static/chunks/0pe7_.ico216u.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>RAG 知识库进阶教程 - AI工具市场</title><meta name=\"description\" content=\"学习 RAG 知识库 的进阶知识\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen bg-gray-50\"><header class=\"bg-white border-b border-gray-200 sticky top-0 z-50\"><div class=\"flex items-center justify-between px-6 py-3\"><a class=\"flex items-center gap-3 hover:opacity-80 transition-opacity\" href=\"/\"><div class=\"w-8 h-8 bg-linear-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center\"><span class=\"text-white text-sm\">⚡</span></div><div class=\"flex flex-col\"><span class=\"text-xl font-bold bg-linear-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent\">AI 工具市场</span></div></a><div class=\"flex items-center gap-4\"><div class=\"relative w-72\"><div class=\"relative\"><svg class=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"></path></svg><input type=\"text\" placeholder=\"全局搜索...\" class=\"w-full pl-9 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all\" value=\"\"/></div></div><a class=\"w-10 h-10 rounded-full bg-gray-100 hover:bg-blue-100 flex items-center justify-center text-lg transition-colors group\" title=\"学院\" href=\"/learn\"><span class=\"group-hover:scale-110 transition-transform\">🎓</span></a><a href=\"http://hsinky.cn\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"w-10 h-10 rounded-full bg-gray-100 hover:bg-purple-100 flex items-center justify-center text-lg transition-colors group\" title=\"个人博客\"><span class=\"group-hover:scale-110 transition-transform\">📰</span></a></div></div></header><div class=\"flex\"><aside class=\"w-72 bg-white border-r border-gray-200 flex flex-col fixed left-0 top-14 h-[calc(100vh-56px)]\"><nav class=\"flex-1 overflow-y-auto p-4\"><div class=\"space-y-1\"><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/\"><span class=\"text-2xl\">🏠</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">首页</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">概览与推荐</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/skill\"><span class=\"text-2xl\">✨</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Skill</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">可复用的能力模块</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/mcp\"><span class=\"text-2xl\">🔌</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">MCP</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">外部工具与服务接入</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/agent\"><span class=\"text-2xl\">🤖</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Agent</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">自主决策的AI助手</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/prompt\"><span class=\"text-2xl\">📝</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Prompt</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">高效沟通的模板</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/workflow\"><span class=\"text-2xl\">🔄</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Workflow</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">多步骤任务编排</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/knowledge\"><span class=\"text-2xl\">🗃️</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Knowledge</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">企业知识智能检索</div></div></a></div></nav><div class=\"shrink-0 p-4 border-t border-gray-100 bg-white\"><div class=\"text-sm text-gray-400\"><div>版本 v1.0.0</div><div class=\"mt-1\">© 2026 AI Tools Center</div></div></div></aside><main class=\"flex-1 ml-72\"><div class=\"p-8\"><nav class=\"flex items-center gap-2 text-sm text-gray-500 mb-6\"><a class=\"hover:text-gray-700 transition-colors\" href=\"/learn\">学院</a><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg><a class=\"hover:text-gray-700 transition-colors\" href=\"/learn/path/developer\">开发者路径</a><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg><span class=\"text-gray-900 font-medium\">RAG 知识库</span></nav><div class=\"bg-gradient-to-r from-emerald-500 to-teal-500 rounded-2xl p-8 text-white mb-8\"><div class=\"flex items-center gap-4 mb-4\"><span class=\"text-4xl\"></span><div><h1 class=\"text-2xl font-bold\">RAG 知识库</h1><p class=\"text-white/80\">RAG 系统实现与优化</p></div></div><div class=\"flex items-center gap-6 text-white/80 text-sm\"><div class=\"flex items-center gap-2\"><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg><span>预计 <!-- -->100分钟</span></div><div class=\"flex items-center gap-2\"><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg><span>开发者路径</span></div></div></div><div class=\"bg-white rounded-xl border border-gray-200 p-4 mb-8\"><div class=\"flex items-center gap-2 text-sm\"><span class=\"text-gray-500\">难度选择：</span><a class=\"px-3 py-1.5 rounded-lg transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200\" href=\"/learn/rag/beginner\">入门路径</a><a class=\"px-3 py-1.5 rounded-lg transition-colors bg-blue-600 text-white\" href=\"/learn/rag/developer\">开发者路径</a><a class=\"px-3 py-1.5 rounded-lg transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200\" href=\"/learn/rag/architect\">架构师路径</a></div></div><div class=\"bg-white rounded-xl border border-gray-200 p-8\"><div class=\"prose prose-gray max-w-none\"><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-sm\">1</span>文档切分策略</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-6\"><div class=\"bg-blue-50 p-4 rounded-lg\"><h4 class=\"font-semibold mb-3 text-blue-700\">切分策略对比</h4><div class=\"space-y-3\"><div class=\"bg-white p-3 rounded border\"><p class=\"font-semibold text-sm\">1. 固定窗口切分</p><p class=\"text-xs text-gray-600 mb-2\">按固定字符数切分，每个Chunk 500-1000 字</p><div class=\"text-xs text-green-600\">优点：简单高效</div><div class=\"text-xs text-red-600\">缺点：可能切断语义完整性</div></div><div class=\"bg-white p-3 rounded border\"><p class=\"font-semibold text-sm\">2. 重叠窗口切分（推荐）</p><p class=\"text-xs text-gray-600 mb-2\">相邻Chunk有部分重叠（如重叠 100 字）</p><div class=\"text-xs text-green-600\">优点：避免信息在边界丢失</div><div class=\"text-xs text-red-600\">缺点：有一定冗余</div></div><div class=\"bg-white p-3 rounded border\"><p class=\"font-semibold text-sm\">3. 语义切分</p><p class=\"text-xs text-gray-600 mb-2\">按段落、章节、句子边界切分</p><div class=\"text-xs text-green-600\">优点：保持语义完整</div><div class=\"text-xs text-red-600\">缺点：Chunk大小不均匀</div></div></div></div><div class=\"bg-gray-100 p-4 rounded-lg\"><h4 class=\"font-semibold mb-3\">代码示例：LangChain 文档切分</h4><div class=\"font-mono text-sm\"><pre>from langchain.text_splitter import (\n    RecursiveCharacterTextSplitter,\n    CharacterTextSplitter\n)\n\n# 推荐：递归切分，智能保持语义\ntext_splitter = RecursiveCharacterTextSplitter(\n    chunk_size=1000,        # 每个 Chunk 的最大字符数\n    chunk_overlap=200,      # 相邻 Chunk 的重叠字符数\n    length_function=len,    # 计算长度的函数\n    separators=[&quot;\\n\\n&quot;, &quot;\\n&quot;, &quot;。&quot;, &quot;，&quot;, &quot; &quot;, &quot;&quot;]\n)\n\nchunks = text_splitter.split_text(large_document)</pre></div></div></div></div></div><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-sm\">2</span>向量检索优化</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-6\"><div class=\"space-y-4\"><div><h4 class=\"font-bold text-lg mb-3\">1. 混合检索（Hybrid Search）</h4><div class=\"bg-purple-50 p-4 rounded-lg\"><p class=\"text-gray-700 mb-3\">结合向量检索（语义）和关键词检索（BM25），取长补短：</p><ul class=\"text-sm text-gray-600 space-y-2\"><li><strong>向量检索</strong>：擅长理解语义、同义词</li><li><strong>关键词检索</strong>：擅长精确匹配专有名词</li><li><strong>混合检索</strong>：加权融合两种结果</li></ul><div class=\"bg-white p-3 rounded border text-xs mt-3\">score = 0.7 * 向量相似度 + 0.3 * BM25 分数</div></div></div><div><h4 class=\"font-bold text-lg mb-3\">2. 查询改写（Query Expansion）</h4><div class=\"bg-green-50 p-4 rounded-lg\"><p class=\"text-gray-700 mb-3\">对用户问题进行改写和扩展，提高召回率：</p><div class=\"bg-white p-2 rounded border text-xs mb-2\"><p>原始问题：&quot;公司有什么产品？&quot;</p><p>改写后：</p><p>  1. &quot;公司有哪些产品？&quot;</p><p>  2. &quot;公司提供什么服务？&quot;</p><p>  3. &quot;公司的主要业务是什么？&quot;</p></div><p class=\"text-sm text-gray-600\">并行检索 3 个问题，合并结果</p></div></div><div><h4 class=\"font-bold text-lg mb-3\">3. 重排序（Reranking）</h4><div class=\"bg-orange-50 p-4 rounded-lg\"><p class=\"text-gray-700 mb-3\">对初步检索结果进行二次排序，提高准确性：</p><div class=\"text-sm text-gray-600 mb-2\"><strong>方法 1：交叉编码器（Cross-Encoder）</strong></div><p class=\"text-xs text-gray-500\">使用更强的模型（如 GPT-4）对检索结果打分排序</p><div class=\"text-sm text-gray-600 mb-2 mt-3\"><strong>方法 2：LLM 评分</strong></div><div class=\"bg-white p-2 rounded border text-xs\"><p>Prompt：&quot;以下哪个文档片段最相关？请按相关性排序&quot;</p></div></div></div></div><div class=\"bg-blue-50 p-4 rounded-lg\"><h4 class=\"font-semibold mb-2 text-blue-700\">性能优化</h4><ul class=\"text-sm text-gray-700 space-y-1\"><li>• <strong>缓存</strong>：相同问题直接复用检索结果</li><li>• <strong>并行查询</strong>：多个改写后的查询并行执行</li><li>• <strong>分片</strong>：大规模数据分片存储</li></ul></div></div></div></div><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-sm\">3</span>Prompt 优化技巧</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-6\"><div class=\"bg-gray-100 p-4 rounded-lg\"><h4 class=\"font-semibold mb-3\">RAG 专用 Prompt 模板</h4><div class=\"font-mono text-sm\"><pre>你是公司的知识助手。\n\n# 知识库内容（按相关性排序，共 {{count}} 条）\n\n{{#each documents}}\n【文档 {{@index}}】\n{{this.content}}\n---\n来源：{{this.source}} | 相关度：{{this.score}}\n{{/each}}\n\n# 用户问题\n{{user_query}}\n\n# 对话历史（如有）\n{{#if chat_history}}\n{{chat_history}}\n{{/if}}\n\n# 回答要求\n\n1. 严格基于【知识库内容】回答\n2. 如果知识库中没有相关信息，明确说明\n3. 引用信息来源：&quot;根据文档X...&quot;\n4. 如果多个文档信息冲突，说明各自观点\n5. 保持{{tone}}的语气\n6. 回答长度不超过{{max_length}}字\n\n# 请回答</pre></div></div><div class=\"space-y-3\"><div class=\"p-3 bg-green-50 rounded-lg\"><h5 class=\"font-semibold mb-1 text-green-700\">关键要素</h5><ul class=\"text-xs text-gray-600 space-y-1\"><li>✓ 按相关性排序展示知识</li><li>✓ 提供来源和相关度分数</li><li>✓ 包含对话历史（支持多轮对话）</li><li>✓ 明确约束（仅基于知识库）</li><li>✓ 处理边界情况（无相关信息）</li></ul></div></div></div></div></div></div></div><div class=\"mt-8 flex items-center justify-between\"><a class=\"flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-4 py-2 rounded-lg hover:bg-gray-50\" href=\"/learn/path/developer\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"></path></svg>返回<!-- -->开发者路径</a><a class=\"flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-4 py-2 rounded-lg hover:bg-gray-50\" href=\"/learn\">返回学院<svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg></a></div></div><!--$--><!--/$--></main></div></div><script src=\"/_next/static/chunks/0j6kpnbwgrhei.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[30824,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"Providers\\\"]\\n3:I[87161,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"default\\\"]\\n4:I[40715,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"default\\\"]\\n5:I[78691,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\",\\\"/_next/static/chunks/0pe7_.ico216u.js\\\"],\\\"default\\\"]\\n6:I[30470,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\",\\\"/_next/static/chunks/0pe7_.ico216u.js\\\"],\\\"default\\\"]\\n8:I[98544,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/