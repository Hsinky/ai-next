o-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":3}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"实验设计步骤\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 1：定义假设**\\n\\\"使用更短的系统提示，用户满意度会提升10%\\\"\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 2：选择指标**\\n- 主要指标：用户满意度评分\\n- 次要指标：响应时间、Token成本\\n- 防护指标：API调用量（确保不会下降）\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 3：确定样本量**\\n根据期望提升幅度和置信度计算：\\n- 期望提升10%\\n- 置信度95%\\n- 计算得到需要10000个用户\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 4：随机分组**\\n- 使用一致性哈希\\n- 固定分组（用户每次进入同一组）\\n- 分组比例：A组50%，B组50%\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 5：运行实验**\\n- 同时运行两个版本\\n- 收集指标数据\\n- 监控异常情况\"}],[\"$\",\"p\",\"5\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 6：分析结果**\\n- 计算差异的置信区间\\n- 判断是否统计显著\\n- 检查防护指标\"}]]}],\"$undefined\",\"$undefined\"]}]\n1d:T6be,import hashlib\n\nclass ABTestManager:\n    def __init__(self, experiment_id: str, group_weights=None):\n        self.experiment_id = experiment_id\n        self.group_weights = group_weights or {\"A\": 0.5, \"B\": 0.5}\n\n    def get_group(self, user_id: str) -> str:\n        \"\"\"根据用户ID获取分组（一致性哈希）\"\"\"\n        # 使用用户ID和实验ID生成哈希\n        hash_input = f\"{self.experiment_id}:{user_id}\"\n        hash_value = hashlib.md5(hash_input.encode()).hexdigest()\n\n        # 将哈希值转换为0-1的数字\n        hash_num = int(hash_value[:8], 16) / (2**32 - 1)\n\n        # 根据权重分配分组\n        cumulative = 0.0\n        for group, weight in self.group_weights.items():\n            cumulative += weight\n            if hash_num < cumulative:\n                return group\n\n        return list(self.group_weights.keys())[-1]\n\n    def get_config(self, group: str) -> dict:\n        \"\"\"获取分组对应的配置\"\"\"\n        configs = {\n            \"A\": {\"model\": \"gpt-3.5-turbo\", \"prompt\": \"简短Prompt\"},\n            \"B\": {\"model\": \"gpt-3.5-turbo\", \"prompt\": \"优化Prompt\"},\n        }\n        return configs.get(group, configs[\"A\"])\n\n# 使用示例\nab_test = ABTestManager(experiment_id=\"prompt_optimization_v1\")\n\ndef handle_chat_request(user_id: str, query: str):\n    # 获取用户分组\n    group = ab_test.get_group(user_id)\n\n    # 获取对应配置\n    config = ab_test.get_config(group)\n\n    # 记录实验事件（用于分析）\n    log_event({\n        \"experiment_id\": ab_test.experiment_id,\n        \"user_id\": user_id,\n        \"group\": group,\n        \"event\": \"chat_request\",\n        \"query\": query\n    })\n\n    # 使用配置处理请求\n    return call_llm_api(query, **config)16:[\"$\",\"div\",\"3\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":4}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"代码示例：A/B分组实现\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"实现用户随机分组：\"}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 bg-gray-900 rounded-lg overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\",\"children\":[\"$\",\"span\",null,{\"className\":\"text-sm text-gray-400 font-mono\",\"children\":\"python\"}]}],[\"$\",\"pre\",null,{\"className\":\"p-4 overflow-x-auto\",\"children\":[\"$\",\"code\",null,{\"className\":\"text-sm text-gray-100 font-mono whitespace-pre\",\"children\":\"$1d\"}]}]]}],\"$undefined\"]}]\n1