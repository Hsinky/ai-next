,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"实验设计步骤\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 1：定义假设**\\n\\\"使用更短的系统提示，用户满意度会提升10%\\\"\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 2：选择指标**\\n- 主要指标：用户满意度评分\\n- 次要指标：响应时间、Token成本\\n- 防护指标：API调用量（确保不会下降）\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 3：确定样本量**\\n根据期望提升幅度和置信度计算：\\n- 期望提升10%\\n- 置信度95%\\n- 计算得到需要10000个用户\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 4：随机分组**\\n- 使用一致性哈希\\n- 固定分组（用户每次进入同一组）\\n- 分组比例：A组50%，B组50%\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 5：运行实验**\\n- 同时运行两个版本\\n- 收集指标数据\\n- 监控异常情况\"}],[\"$\",\"p\",\"5\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Step 6：分析结果**\\n- 计算差异的置信区间\\n- 判断是否统计显著\\n- 检查防护指标\"}]]}],\"$undefined\",\"$undefined\"]}]\n1d:T6be,import hashlib\n\nclass ABTestManager:\n    def __init__(self, experiment_id: str, group_weights=None):\n        self.experiment_id = experiment_id\n        self.group_weights = group_weights or {\"A\": 0.5, \"B\": 0.5}\n\n    def get_group(self, user_id: str) -> str:\n        \"\"\"根据用户ID获取分组（一致性哈希）\"\"\"\n        # 使用用户ID和实验ID生成哈希\n        hash_input = f\"{self.experiment_id}:{user_id}\"\n        hash_value = hashlib.md5(hash_input.encode()).hexdigest()\n\n        # 将哈希值转换为0-1的数字\n        hash_num = int(hash_value[:8], 16) / (2**32 - 1)\n\n        # 根据权重分配分组\n        cumulative = 0.0\n        for group, weight in self.group_weights.items():\n            cumulative += weight\n            if hash_num < cumulative:\n                return group\n\n        return list(self.group_weights.keys())[-1]\n\n    def get_config(self, group: str) -> dict:\n        \"\"\"获取分组对应的配置\"\"\"\n        configs = {\n            \"A\": {\"model\": 