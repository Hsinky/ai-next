",\\\"p\\\",\\\"2\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**风险三：有害输出**\\\\n- 生成暴力、歧视内容\\\\n- 提供非法建议\\\\n- 泄露商业机密\\\"}],[\\\"$\\\",\\\"p\\\",\\\"3\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**风险四：模型窃取**\\\\n- 通过API查询重建模型\\\\n- 知识产权被盗\\\\n- 竞争对手复制\\\"}],[\\\"$\\\",\\\"p\\\",\\\"4\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**风险五：滥用风险**\\\\n- 批量生成垃圾内容\\\\n- 自动化攻击脚本\\\\n- 社交工程攻击\\\"}]]}],\\\"$undefined\\\",[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-4 p-4 bg-blue-50 rounded-lg border border-blue-200\\\",\\\"children\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-sm text-blue-900 font-medium\\\",\\\"children\\\":[\\\"💡 \\\",\\\"AI应用面临数据泄露、Prompt注入、有害输出、模型窃取、滥用等安全风险。\\\"]}]}]]}]\\n14:[\\\"$\\\",\\\"div\\\",\\\"2\\\",{\\\"className\\\":\\\"mb-8 last:mb-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\\\",\\\"children\\\":3}],[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-gray-900\\\",\\\"children\\\":\\\"数据隐私保护\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**原则**：最小化收集，最大化保护\\\"}],[\\\"$\\\",\\\"p\\\",\\\"1\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**保护措施**：\\\"}],[\\\"$\\\",\\\"p\\\",\\\"2\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**1. 输入过滤**\\\\n- PII检测：识别并脱敏敏感信息\\\\n- 关键词过滤：阻止危险输入\\\\n- 格式检查：验证输入合法性\\\"}],[\\\"$\\\",\\\"p\\\",\\\"3\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**2. 输出审计**\\\\n- 敏感词检测\\\\n- 事实性验证\\\\n- 格式校验\\\"}],[\\\"$\\\",\\\"p\\\",\\\"4\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**3. 数据存储**\\\\n- 加密存储（AES-256）\\\\n- 访问控制（RBAC）\\\\n- 审计日志\\\"}],[\\\"$\\\",\\\"p\\\",\\\"5\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**4. 数据处理**\\\\n- 不存储原始输入（可选用）\\\\n- 定期删除历史数据\\\\n- 匿名化处理\\\"}],[\\\"$\\\",\\\"p\\\",\\\"6\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**示例：PII检测与脱敏**\\\\n```\\\\n输入：\\\\\\\"我的手机号是13812345678\\\\\\\"\\\\n检测：识别11位手机号\\\\n脱敏：\\\\\\\"我的手机号是138****5678\\\\\\\"\\\\n```\\\"}]]}],\\\"$undefined\\\",\\\"$undefined\\\"]}]\\n1c:T7bf,\"])</script><script>self.__next_f.push([1,\"import re\\nfrom typing import List, Tuple\\n\\nclass PIIDetector:\\n    \\\"\\\"\\\"敏感信息检测与脱敏\\\"\\\"\\\"\\n\\n    def __init__(self):\\n        self.patterns = {\\n            \\\"phone\\\": (r'1[3-9]\\\\d{9}', self._mask_phone),\\n            \\\"id_card\\\": (r'\\\\d{17}[\\\\dXx]', self._mask_id_card),\\n            \\\"email\\\": (r'[\\\\w.-]+@[\\\\w.-]+\\\\.\\\\w+', self._mask_email),\\n            \\\"credit_card\\\": (r'\\\\d{13,19}', self._mask_credit_card),\\n        }\\n\\n    def detect_and_mask(self, text: str) -\\u003e Tuple[str, List[dict]]:\\n        \\\"\\\"\\\"检测并脱敏敏感信息\\\"\\\"\\\"\\n        masked_text = text\\n        detected = []\\n\\n        for pii_type, (pattern, mask_func) in self.patterns.items():\\n            matches = re.findall(pattern, text)\\n            for match in matches:\\n                # 记录检测结果\\n                detected.append({\\n                    \\\"type\\\": pii_type,\\n                    \\\"value\\\": match,\\n                    \\\"position\\\": text.find(match)\\n                })\\n                # 脱敏处理\\n                masked_value = mask_func(match)\\n                masked_text = masked_text.replace(match, masked_value, 1)\\n\\n        return masked_text, detected\\n\\n    def _mask_phone(self, phone: str) -\\u003e str:\\n        \\\"\\\"\\\"手机号脱敏：138****5678\\\"\\\"\\\"\\n        return phone[:3] + \\\"****\\\" + phone[-4:]\\n\\n    def _mask_id_card(self, id_card: str) -\\u003e str:\\n        \\\"\\\"\\\"身份证脱敏：110***********1234\\\"\\\"\\\"\\n        return id_card[:3] + \\\"***********\\\" + id_card[-4:]\\n\\n    def _mask_email(self, email: str) -\\u003e str:\\n        \\\"\\\"\\\"邮箱脱敏：a***@example.com\\\"\\\"\\\"\\n        parts = email.split(\\\"@\\\")\\n        return parts[0][0] + \\\"***@\\\" + parts[1]\\n\\n    def _mask_credit_card(self, card: str) -\\u003e str:\\n        \\\"\\\"\\\"银行卡脱敏：**** **** **** 1234\\\"\\\"\\\"\\n        return \\\"**** **** **** \\\" + card[-4:]\\n\\n# 使用示例\\ndetector = PIIDetector()\\ntext = \\\"我的手机是13812345678，邮箱是zhang@example.com\\\"\\nmasked, detected = detector.detect_and_mask(text)\\nprint(masked)\\n# 输出：我的手机是138****5678，邮箱是z***@example.com\"])</script><script>self.__next_f.push([1,\"15:[\\\"$\\\",\\\"div\\\",\\\"3\\\",{\\\"className\\\":\\\"mb-8 last:mb-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\\\",\\\"children\\\":4}],[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-gray-900\\\",\\\"children\\\":\\\"代码示例：敏感信息检测\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"实现PII检测和脱敏：\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-4 bg-gray-900 rounded-lg overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-sm text-gray-400 font-