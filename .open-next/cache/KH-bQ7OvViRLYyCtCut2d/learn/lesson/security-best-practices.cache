\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**1. 网络层**\\\\n- 防火墙：限制入站/出站流量\\\\n- DDoS防护：流量清洗\\\\n- WAF：Web应用防火墙\\\"}],[\\\"$\\\",\\\"p\\\",\\\"3\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**2. 应用层**\\\\n- 认证授权：OAuth 2.0、JWT\\\\n- 输入验证：白名单、格式检查\\\\n- 输出编码：防止XSS\\\"}],[\\\"$\\\",\\\"p\\\",\\\"4\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**3. API层**\\\\n- 速率限制：防止滥用\\\\n- API Key管理：定期轮换\\\\n- 请求签名：防篡改\\\"}],[\\\"$\\\",\\\"p\\\",\\\"5\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**4. 数据层**\\\\n- 加密：传输（TLS）、存储（AES）\\\\n- 访问控制：最小权限\\\\n- 审计日志：可追溯\\\"}],[\\\"$\\\",\\\"p\\\",\\\"6\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**5. 模型层**\\\\n- 输入过滤：PII检测、Prompt注入检测\\\\n- 输出审计：内容审核、事实检查\\\\n- 调用限制：防止模型滥用\\\"}]]}],\\\"$undefined\\\",[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-4 p-4 bg-blue-50 rounded-lg border border-blue-200\\\",\\\"children\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-sm text-blue-900 font-medium\\\",\\\"children\\\":[\\\"💡 \\\",\\\"采用纵深防御原则，在多个层次实施安全措施，避免单点失败。\\\"]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"14:[\\\"$\\\",\\\"div\\\",\\\"2\\\",{\\\"className\\\":\\\"mb-8 last:mb-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\\\",\\\"children\\\":3}],[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-gray-900\\\",\\\"children\\\":\\\"安全开发生命周期（SDL）\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**阶段一：需求分析**\\\\n- 安全需求文档\\\\n- 威胁建模（STRIDE）\\\\n- 隐私影响评估\\\"}],[\\\"$\\\",\\\"p\\\",\\\"1\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**阶段二：设计**\\\\n- 安全架构设计\\\\n- 数据流图\\\\n- 安全设计评审\\\"}],[\\\"$\\\",\\\"p\\\",\\\"2\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**阶段三：开发**\\\\n- 安全编码规范\\\\n- 代码审查\\\\n- 安全测试\\\"}],[\\\"$\\\",\\\"p\\\",\\\"3\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**阶段四：测试**\\\\n- 渗透测试\\\\n- 安全扫描\\\\n- 修复验证\\\"}],[\\\"$\\\",\\\"p\\\",\\\"4\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**阶段五：部署**\\\\n- 安全配置检查\\\\n- 环境隔离\\\\n- 变更审批\\\"}],[\\\"$\\\",\\\"p\\\",\\\"5\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**阶段六：运维**\\\\n- 监控告警\\\\n- 漏洞管理\\\\n- 应急响应\\\"}],[\\\"$\\\",\\\"p\\\",\\\"6\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**持续改进**：\\\\n- 定期安全评估\\\\n- 事件复盘\\\\n- 培训教育\\\"}]]}],\\\"$undefined\\\",\\\"$undefined\\\"]}]\\n1c:T890,\"])</script><script>self.__next_f.push([1,\"from functools import wraps\\nfrom flask import request, jsonify\\nimport time\\nimport hmac\\nimport hashlib\\n\\n# 1. 速率限制\\nclass RateLimiter:\\n    def __init__(self, max_requests=100, window=60):\\n        self.max_requests = max_requests\\n        self.window = window\\n        self.requests = {}\\n\\n    def is_allowed(self, client_id: str) -\\u003e bool:\\n        now = time.time()\\n        if client_id not in self.requests:\\n            self.requests[client_id] = []\\n\\n        # 清理过期记录\\n        self.requests[client_id] = [\\n            t for t in self.requests[client_id]\\n            if now - t \\u003c self.window\\n        ]\\n\\n        if len(self.requests[client_id]) \\u003e= self.max_requests:\\n            return False\\n\\n        self.requests[client_id].append(now)\\n        return True\\n\\n# 2. 请求签名验证\\ndef verify_signature(api_key: str, secret: str, timestamp: str, signature: str) -\\u003e bool:\\n    \\\"\\\"\\\"验证请求签名\\\"\\\"\\\"\\n    expected = hmac.new(\\n        secret.encode(),\\n        f\\\"{api_key}{timestamp}\\\".encode(),\\n        hashlib.sha256\\n    ).hexdigest()\\n    return hmac.compare_digest(expected, signature)\\n\\n# 3. 安全中间件组合\\ndef security_middleware(rate_limiter):\\n    def decorator(f):\\n        @wraps(f)\\n        def wrapped(*args, **kwargs):\\n            # 速率限制\\n            client_id = request.headers.get('X-API-Key', 'anonymous')\\n            if not rate_limiter.is_allowed(client_id):\\n                return jsonify({\\\"error\\\": \\\"Rate limit exceeded\\\"}), 429\\n\\n            # 签名验证（可选）\\n            if 'X-Signature' in request.headers:\\n                timestamp = request.headers.get('X-Timestamp', '')\\n                signature = request.headers.get('X-Signature', '')\\n                # 验证签名...\\n\\n            # 输入验证\\n            content_type = request.content_type or ''\\n            if 'application/json' not in content_type:\\n                return jsonify({\\\"error\\\": \\\"Invalid content type\\\"}), 400\\n\\n            return f(*args, **kwargs)\\n        return wrapped\\n    return decorator\\n\\n# 使用\\nlimiter = RateLimiter(max_requests=100, window=60)\\n\\n@app.route('/api/chat', methods=['POST'])\\n@security_middleware(limiter)\\ndef chat():\\n    return {\\\"response\\\": \\\"Hello\\\"}  \"])</script><script>self.__next_f.push([1,\"15:[\\\"$\\\",\\\"div\\\",\\\"3\\\",{\\\"className\\\":\\\"mb-8 last:mb-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\\\",\\\"children\\\":4}],[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-gray-900\\\",\\\"children\\\":\\\"代码示例：API安全中间件\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed space-y-4\\\",\\\"c