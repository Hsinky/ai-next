_throughput.labels(model='gpt-4').inc(len(result))5:[\"$\",\"div\",\"3\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":4}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"代码示例：性能指标收集\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"使用Prometheus收集性能指标：\"}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 bg-gray-900 rounded-lg overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\",\"children\":[\"$\",\"span\",null,{\"className\":\"text-sm text-gray-400 font-mono\",\"children\":\"python\"}]}],[\"$\",\"pre\",null,{\"className\":\"p-4 overflow-x-auto\",\"children\":[\"$\",\"code\",null,{\"className\":\"text-sm text-gray-100 font-mono whitespace-pre\",\"children\":\"$e\"}]}]]}],\"$undefined\"]}]\n6:[\"$\",\"div\",\"4\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":5}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"性能优化技巧\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**1. 减少网络往返**\\n- 批量API调用\\n- 合并请求\\n- 使用连接池\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**2. 优化模型调用**\\n- 批处理：一次处理多个输入\\n- KV Cache：复用计算结果\\n- 量化：使用量化模型（INT8/INT4）\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**3. 缓存策略**\\n- 请求结果缓存\\n- 中间结果缓存\\n- 预加载热门数据\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**4. 并发处理**\\n- 异步IO（asyncio）\\n- 并发请求（requests并发）\\n- 流式输出\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**5. 数据处理优化**\\n- 向量化计算（NumPy）\\n- 数据库索引优化\\n- 避免N+1查询\"}]]}],\"$undefined\",\"$undefined\"]}]\n7:[\"$\",\"div\",\"5\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":6}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"代码示例：异步并发调用\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"使用asyncio并发处理多个请求：\"}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 bg-gray-900 rounded-lg overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\",\"children\":[\"$\",\"span\",null,{\"className\":\"text-sm text-gray-400 font-mono\",\"children\":\"python\"}]}],[\"$\",\"pre\",null,{\"className\":\"p-4 overflow-x-auto\",\"children\":[\"$\",\"code\",null,{\"className\":\"text-sm text-gray-100 font-mono whitespace-pre\",\"children\":\"import asyncio\\nimport aiohttp\\n\\nasync def fetch_with_timeout(session, url, timeout=10):\\n    \\\"\\\"\\\"带超时的异步请求\\\"\\\"\\\"\\n    try:\\n        async with session.get(url, timeout=timeout) as response:\\n            return await response.json()\\n    except asyncio.TimeoutError:\\n        return {\\\"error\\\": \\\"timeout\\\"}\\n\\nasync def parallel_llm_calls(queries: list, max_concurrent=5):\\n    \\\"\\\"\\\"并发调用LLM API\\\"\\\"\\\"\\n    semaphore = asyncio.Semaphore(max_concurrent)\\n\\n    async def bounded_call(query):\\n        async with semaphore:\\n            # 模拟API调用\\n            return await fetch_with_timeout(\\n                session=f\\\"api.example.com\\\",\\n                url=f\\\"/api/chat?q={query}\\\"\\n            )\\n\\n    async with aiohttp.ClientSession() as session:\\n        # 并发执行所有请求\\n        results = await asyncio.gather(\\n            *[bounded_call(q) for q in queries],\\n            return_exceptions=True\\n        )\\n\\n        return results\\n\\n# 使用示例\\nqueries = [\\\"What is AI?\\\", \\\"Explain ML\\\", \\\"Tell me about Python\\\"]\\nresults = asyncio.run(parallel_llm_calls(queries))\"}]}]]}],\"$undefined\"]}]\n8:[\"$\",\"div\",\"6\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":7}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"实战：慢查询诊断\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**问题**：某API P99延迟达到5秒\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**诊断步骤**：\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"1. **查看追踪数据**\\n   - 数据库查询：2.5秒\\n   - LLM调用：2秒\\n   - 其他处理：0.5秒\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"2. **深入分析**\\n   - 数据库：发现一个N+1查询问题\\n   - LLM：模型选择不合适，用了超大模型\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"3. **优化措施**\\n   - 数据库：添加索引，修复N+1查询 → 降至0.2秒\\n   - LLM：换用中等模型 → 降至1秒\"}],[\"$\",\"p\",\"5\",{\"className\":\"whitespace-pre-line\",\"children\":\"4. **结果**\\