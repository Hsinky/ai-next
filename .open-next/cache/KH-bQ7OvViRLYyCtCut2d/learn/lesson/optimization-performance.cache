,null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"AI应用性能指标\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**关键指标**：\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**1. 响应时间（Latency）**\\n- P50：50%请求的响应时间\\n- P95：95%请求的响应时间（关注长尾）\\n- P99：99%请求的响应时间\\n- TTFB：首字节时间（Time to First Byte）\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**2. 吞吐量（Throughput）**\\n- QPS：每秒查询数\\n- RPS：每秒请求数\\n- TPM：每分钟Token数\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**3. 资源利用率**\\n- GPU利用率：理想70-90%\\n- 内存使用率：避免OOM\\n- CPU利用率：平稳负载\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**4. 错误率**\\n- HTTP错误率（4xx, 5xx）\\n- 模型调用失败率\\n- 超时率\"}],[\"$\",\"p\",\"5\",{\"className\":\"whitespace-pre-line\",\"children\":\"**5. 用户体验指标**\\n- 流式输出的首Token时间（TTFT）\\n- 感知延迟（用户开始打字到看到输出）\\n- 完成率（请求完成的百分比）\"}]]}],\"$undefined\",[\"$\",\"div\",null,{\"className\":\"mt-4 p-4 bg-blue-50 rounded-lg border border-blue-200\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm text-blue-900 font-medium\",\"children\":[\"💡 \",\"关注P95/P99长尾延迟，不只是平均值；TTFT影响用户体验。流式输出的首Token时间是关键指标。\"]}]}]]}]\n14:[\"$\",\"div\",\"2\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":3}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"性能监控工具\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**APM工具**：\\n- Datadog、New Relic：全栈监控\\n- Grafana+Prometheus：开源方案\\n- Lightstep：分布式追踪\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**AI专用监控**：\\n- LangSmith：LLM应用监控\\n- Weights & Biases：模型实验追踪\\n- Arize：模型性能监控\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**基础监控指标**：\\n```yaml\\nmetrics:\\n  - name: response_time_p99\\n    type: histogram\\n    labels: [endpoint, model]\\n  - name: gpu_utilization\\n    type: gauge\\n    labels: [gpu_id, model]\\n  - name: token_throughput\\n    type: counter\\n    labels: [model]\\n  - name: error_rate\\n    type: gauge\\n    labels: [endpoint, error_type]\\n```\"}]]}],\"$undefined\",\"$undefined\"]}]\n1d:T463,from prometheus_client import Counter, Histogram, Gauge, start_http_server\n\n# 定义指标\nresponse_time = Histogram(\n    'api_response_time_seconds',\n    'API响应时间',\n    ['endpoint', 'model']\n)\n\ntoken_throughput = Counter(\n    'token_throughput_total',\n    'Token吞吐量',\n    ['model']\n)\n\ngpu_utilization = Gauge(\n    'gpu_utilization_percent',\n    'GPU利用率',\n    ['gpu_id', 'model']\n)\n\nerror_count = Counter(\n    'api_error_count_total',\n    'API错误计数',\n    ['endpoint', 'error_type']\n)\n\n# 使用示例\nimport time\nfrom contextlib import contextmanager\n\n@contextmanager\ndef track_api_call(endpoint: str, model: str):\n    \"\"\"追踪API调用\"\"\"\n    start = time.time()\n    try:\n        yield\n    except Exception as e:\n        error_count.labels(endpoint=endpoint, error_type=type(e).__name__).inc()\n        raise\n    finally:\n        duration = time.time() - start\n        response_time.labels(endpoint=endpoint, model=model).observe(duration)\n\n# 在API中使用\nwith track_api_call('/api/chat', 'gpt-4'):\n    result = call_llm_api(\"Hello\")\n    token_throughput.labels(model='gpt-4').inc(len(result))15:[\"$\",\"div\",\"3\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":4}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"代码示例：性能指标收集\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"使用Prometheus收集性能指标：\"}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 bg-gray-900 rounded-lg overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\",\"children\":[\"$\",\"span\",null,{\"className\":\"text-sm text-gray-400 font-mono\",\"children\":\"python\"}]}],[\"$\",\"pre\",null,{\"className\":\"p-4 overflow-x-auto\",\"children\":[\"$\",\"code\",null,{\"className\":\"text-sm text-gray-100 font-mono whitespace-pre\",\"children\":\"$1d\"}]}]]}],\"$undefined\"]}]\n16:[\"$\",\"div\",\"4\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":5}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"性能优化技巧\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**1. 减少网络往返**\\n- 批量API调用\\n- 合并请求\\n- 使用连接池\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**2. 优化模型调用**\\n- 批处理：一次处理多个输入\\n- KV Cache：复用计算结果\\n- 量化：使用量化模型（INT8/INT4）\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**3. 缓存策略**\\n- 请求结果缓存\\n- 中间结果缓存\\n- 预加载热门数据\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**4. 并发处理**\\n- 异步IO（asyncio）\\n- 并发请求（requests并发）\\n- 流式输出\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**5. 数据处理优化**\\n- 向量化计算（NumPy）\\n- 数据库索引优化\\n- 避免N+1查询\"}]]}],\"$undefined\",\"$undefined\"]}]\n17:[\"$\",\"div\",\"5\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":6}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"代码示例：异步并发调用\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"使用asyncio并发处理多个请求：\"}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 bg-gray-900 rounded-lg overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\",\"children\":[\"$\",\"span\",null,{\"className\":\"text-sm text-gray-400 font-mono\",\"children\":\"python\"}]}],[\"$\",\"pre\",null,{\"className\":\"p-4 overflow-x-auto\",\"children\":[\"$\",\"code\",null,{\"className\":\"text-sm text-gray-100 font-mono whitespace-pre\",\"children\":\"import asyncio\\nimport aiohttp\\n\\nasync def fetch_with_timeout(session, url, timeout=10):\\n    \\\"\\\"\\\"带超时的异步请求\\\"\\\"\\\"\\n    try:\\n        async with session.get(url, timeout=timeout) as response:\\n            return await response.json()\\n    except asyncio.TimeoutError:\\n        return {\\\"error\\\": \\\"timeout\\\"}\\n\\nasync def parallel_llm_calls(queries: list, max_concurrent=5):\\n    \\\"\\\"\\\"并发调用LLM API\\\"\\\"\\\"\\n    semaphore = asyncio.Semaphore(max_concurrent)\\n\\n    async def bounded_call(query):\\n        async with semaphore:\\n            # 模拟API调用\\n            return await fetch_with_timeout(\\n                session=f\\\"api.example.com\\\",\\n                url=f\\\"/api/chat?q={query}\\\"\\n            )\\n\\n    async with aiohttp.ClientSession() as session:\\n        # 并发执行所有请求\\n        results = await asyncio.gather(\\n            *[bounded_call(q) for q in queries],\\n            return_exceptions=True\\n        )\\n\\n        return results\\n\\n# 使用示例\\nqueries = [\\\"What is AI?\\\", \\\"Explain ML\\\", \\\"Tell me about Python\\\"]\\nresults = asyncio.run(parallel_llm_calls(queries))\"}]}]]}],\"$undefined\"]}]\n18:[\"$\",\"div\",\"6\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":7}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"实战：慢查询诊断\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**问题**：某API P99延迟达到5秒\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**诊断步骤**：\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"1. **查看追踪数据**\\n   - 数据库查询：2.5秒\\n   - LLM调用：2秒\\n   - 其他处理：0.5秒\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"2. **深入分析**\\n   - 数据库：发现一个N+1查询问题\\n   - LLM：模型选择不合适，用了超大模型\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"3. **优化措施**\\n   - 数据库：添加索引，修复N+1查询 → 降至0.2秒\\n   - LLM：换用中等模型 → 降至1秒\"}],[\"$\",\"p\",\"5\",{\"className\":\"whitespace-pre-line\",\"children\":\"4. **结果**\\n   - P99延迟：5秒 → 1.7秒\\n   - 成本降低40%\"}]]}],\"$undefined\",\"$undefined\"]}]\n19:[\"$\",\"div\",\"7\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-