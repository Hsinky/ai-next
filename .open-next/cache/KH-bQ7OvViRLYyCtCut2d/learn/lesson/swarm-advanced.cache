时间\\\\n- 错误率\\\"}],[\\\"$\\\",\\\"p\\\",\\\"2\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**消息级别**：\\\\n- 消息吞吐量：消息/秒\\\\n- 消息延迟：P50/P95/P99\\\\n- 队列积压：pending消息数\\\\n- 消息丢失率\\\"}],[\\\"$\\\",\\\"p\\\",\\\"3\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**协作级别**：\\\\n- 协商耗时：达成共识的平均时间\\\\n- 冲突次数：协商不一致的次数\\\\n- 重试次数：任务重试比例\\\"}],[\\\"$\\\",\\\"p\\\",\\\"4\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**拓扑级别**：\\\\n- Agent数量变化：新加入/退出\\\\n- 连接健康：Agent间连接状态\\\\n- 系统吞吐：整体任务处理能力\\\"}],[\\\"$\\\",\\\"p\\\",\\\"5\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**监控实现**：\\\"}],[\\\"$\\\",\\\"p\\\",\\\"6\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"```\\\\n# 每个Agent上报指标\\\\nclass MetricsCollector:\\\\n    def record_agent_status(self, agent_id, status):\\\\n        self.metrics[\\\\\\\"agent_status\\\\\\\"][agent_id] = {\\\\n            \\\\\\\"status\\\\\\\": status,\\\\n            \\\\\\\"timestamp\\\\\\\": time.time()\\\\n        }\\\"}],[\\\"$\\\",\\\"p\\\",\\\"7\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"    def record_message_latency(self, from_id, to_id, latency_ms):\\\\n        self.metrics[\\\\\\\"message_latency\\\\\\\"].append({\\\\n            \\\\\\\"from\\\\\\\": from_id,\\\\n            \\\\\\\"to\\\\\\\": to_id,\\\\n            \\\\\\\"latency_ms\\\\\\\": latency_ms\\\\n        })\\\"}],[\\\"$\\\",\\\"p\\\",\\\"8\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"    def get_dashboard(self):\\\\n        \\\\\\\"\\\\\\\"\\\\\\\"生成监控Dashboard数据\\\\\\\"\\\\\\\"\\\\\\\"\\\\n        return {\\\\n            \\\\\\\"total_agents\\\\\\\": len(self.metrics[\\\\\\\"agent_status\\\\\\\"]),\\\\n            \\\\\\\"active_agents\\\\\\\": sum(\\\\n                1 for s in self.metrics[\\\\\\\"agent_status\\\\\\\"].values()\\\\n                if s[\\\\\\\"status\\\\\\\"] == \\\\\\\"available\\\\\\\"\\\\n            ),\\\\n            \\\\\\\"avg_latency\\\\\\\": sum(\\\\n                m[\\\\\\\"latency_ms\\\\\\\"] for m in self.metrics[\\\\\\\"message_latency\\\\\\\"]\\\\n            ) / len(self.metrics[\\\\\\\"message_latency\\\\\\\"]),\\\\n            ...\\\\n        }\\\\n```\\\"}]]}],\\\"$undefined\\\",\\\"$undefined\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"1c:Te45,\"])</script><script>self.__next_f.push([1,\"import time\\nfrom typing import List, Dict, Optional\\nfrom dataclasses import dataclass\\n\\n@dataclass\\nclass Task:\\n    id: str\\n    required_capability: str\\n    payload: dict\\n    priority: int = 1\\n    status: str = \\\"pending\\\"\\n    assigned_agent: Optional[str] = None\\n\\nclass AdvancedSwarmOrchestrator:\\n    def __init__(self):\\n        self.agents: Dict[str, dict] = {}\\n        self.tasks: Dict[str, Task] = {}\\n        self.task_queue: List[str] = []\\n\\n    def register_agent(self, agent_id: str, capabilities: List[str], endpoint: str):\\n        \\\"\\\"\\\"注册Agent\\\"\\\"\\\"\\n        self.agents[agent_id] = {\\n            \\\"capabilities\\\": capabilities,\\n            \\\"endpoint\\\": endpoint,\\n            \\\"status\\\": \\\"available\\\",\\n            \\\"last_heartbeat\\\": time.time(),\\n            \\\"load\\\": 0\\n        }\\n        print(f\\\"Agent {agent_id} 注册成功，能力: {capabilities}\\\")\\n\\n    def submit_task(self, task: Task):\\n        \\\"\\\"\\\"提交任务\\\"\\\"\\\"\\n        self.tasks[task.id] = task\\n        # 按优先级插入队列\\n        inserted = False\\n        for i, tid in enumerate(self.task_queue):\\n            if self.tasks[tid].priority \\u003c task.priority:\\n                self.task_queue.insert(i, task.id)\\n                inserted = True\\n                break\\n        if not inserted:\\n            self.task_queue.append(task.id)\\n\\n        print(f\\\"任务 {task.id} 已提交，优先级: {task.priority}\\\")\\n\\n    def schedule_tasks(self):\\n        \\\"\\\"\\\"调度任务\\\"\\\"\\\"\\n        while self.task_queue:\\n            task_id = self.task_queue.pop(0)\\n            task = self.tasks[task_id]\\n\\n            # 查找可用Agent\\n            available_agents = [\\n                (aid, info) for aid, info in self.agents.items()\\n                if task.required_capability in info[\\\"capabilities\\\"]\\n                and info[\\\"status\\\"] == \\\"available\\\"\\n                and info[\\\"load\\\"] \\u003c 5  # 负载限制\\n            ]\\n\\n            if not available_agents:\\n                # 没有可用Agent，重新入队\\n                self.task_queue.append(task_id)\\n                print(f\\\"任务 {task_id} 没有可用Agent，等待...\\\")\\n                break\\n\\n            # 选择负载最低的Agent\\n            best_agent = min(available_agents, key=lambda x: x[1][\\\"load\\\"])\\n            agent_id, _ = best_agent\\n\\n            # 分配任务\\n            self._assign_task(agent_id, task)\\n            print(f\\\"任务 {task.id} 分配给 {agent_id}\\\")\\n\\n    def _assign_task(self, agent_id: str, task: Task):\\n        \\\"\\\"\\\"分配任务给Agent\\\"\\\"\\\"\\n        task.assigned_agent = agent_id\\n        task.status = \\\"assigned\\\"\\n        self.agents[agent_id][\\\"load\\\"] += 1\\n        self.agents[agent_id][\\\"status\\\"] = \\\"busy\\\"\\n\\n        # 这里应该通过RPC调用Agent执行任务\\n        # self._call_agent(agent_id, task)\\n\\n    def complete_task(self, task_id: str, agent_id: str):\\n        \\\"\\\"\\\"完成任务\\\"\\\"\\\"\\n        task = self.tasks[task_id]\\n        task.status = \\\"completed\\\"\\n        self.agents[agent_id][\\\"load\\\"] -= 1\\n        if self.agents[agent_id][\\\"load\\\"] == 0:\\n            self.agents[agent_id][\\\"status\\\"] = \\\"available\\\"\\n        print(f\\\"任务 {task_id} 由 {agent_id} 完成\\\")\\n\\n# 使用示例\\norchestrator = AdvancedSwarmOrchestrator()\\n\\n# 注册Agent\\norchestrator.register_agent(\\\"agent_1\\\", [\\\"research\\\", \\\"analysis\\\"], \\\"http://localhost:8001\\\")\\norchestrator.register_agent(\\\"agent_2\\\", [\\\"writing\\\", \\\"editing\\\"], \\\"http://localhost:8002\\\")\\norchestrator.register_agent(\\\"agent_3\\\", [\\\"research\\\", \\\"analysis\\\"], \\\"http://localhost:8003\\\")\\n\\n# 提交任务\\norchestrator.submit_task(Task(\\\"task_1\\\", \\\"research\\\", {\\\"topic\\\": \\\"AI趋势\\\"}))\\norchestrator.submit_task(Task(\\\"task_2\\\", \\\"writing\\\", {\\\"content\\\": \\\"报告大纲\\\"}, priority=2))\\n\\n# 调度\\norchestrator.schedule_tasks()\"])</script><script>self.__next_f.push([1,\"16:[\\\"$\\\",\\\"div\\\",\\\"4\\\",{\\\"className\\\":\\\"mb-8 last:mb-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\\\",\\\"children\\\":5}],[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-gray-900\\\",\\\"children\\\":\\\"代码示例：高级Swarm协调器\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"实现动态Agent分配和任务监控：\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-4 bg-gray-900 rounded-lg overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-sm text-gray-400 font-mono\\\",\\\"children\\\":\\\"python\\\"}]}],[\\\"$\\\",\\\"pre\\\",null,{\\\"className\\\":\\\"p-4 overflow-x-auto\\\",\\\"children\\\":[\\\"$\\\",\\\"code\\\",null,{\\\"className\\\":\\\"text-sm text-gray-100 font-mono whitespace-pre\\\",\\\"children\\\":\\\"$1c\\\"}]}]]}],\\\"$undefined\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"17:[\\\"$\\\",\\\"div\\\",\\\"5\\\",{\\\"className\\\":\\\"mb-8 last:mb-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\\\",\\\"children\\\":6}],[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-gray-900\\\",\\\"children\\\":\\\"实战：企业级知识Swarm\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**场景**：企业知识处理系统\\\"}],[\\\"$\\\",\\\"p\\\",\\\"1\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**Swarm组成**：\\\"}],[\\\"$\\\",\\\"p\\\",\\\"2\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"1. **Ingestion Agents** (数据采集)\\\\n   - WebCrawler: 爬取公开资讯\\\\n   - EmailCollector: 收集邮件\\\\n   - DocumentParser: 解析PDF/Word\\\\n   - 每类Agent可多实例并行\\\"}],[\\\"$\\\",\\\"p\\\",\\\"3\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"2. **Processing Agents** (数据处理)\\\\n   - Extractor: 提取关键信息\\\\n   - Classifier: 内容分类打标\\\\n   - Embedder: 生成向量\\\\n   - Queue: 任务队列分发\\\"}],[\\\"$\\\",\\\"p\\\",\\\"4\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"3. **Analysis Agents** (分析推理)\\\\n   - Summarizer: 生成摘要\\\\n   - InsightAgent: 发现洞察\\\\n   - TrendAgent: 识别趋势\\\"}],[\\\"$\\\",\\\"p\\\",\\\"5\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"4. **Storage Agents** (存储管理)\\\\n   - VectorDB: 存储向量\\\\n   - DocumentDB: 存储原文\\\\n   - CacheManager: 管理缓存\\\"}],[\\\"$\\\",\\\"p\\\",\\\"6\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"5. **Gateway Agent** (网关管理)\\\\n   - 路由Agent: 分发请求\\\\n   - MonitorAgent: 监控状态\\\\n   - HealAgent: 自愈恢复\\\"}],[\\\"$\\\",\\\"p\\\",\\\"7\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**架构图**：\\\\n```\\\\n外部源 → Ingestion Agents → Queue → Processing Agents\\\\n                                 ↓\\\\n                            Analysis Agents\\\\n                                 ↓\\\\n                            Storage Agents\\\\n                                 ↓\\\\n                            Gateway → 用户\\\\n```\\\"}],[\\\"$\\\",\\\"p\\\",\\\"8\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**关键特性**：\\\\n- 动态扩缩容：高负载自动增加Agent实例\\\\n- 故障自愈：Agent失败自动重启和重新分配\\\\n- 负载均衡：任务均匀分配\\\\n- 实时监控：Dashboard展示Agent状态和任务进度\\\"}]]}],\\\"$undefined\\\",\\\"$undefined\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"18:[\\\"$\\\",\\\"div\\\",\\\"6\\\",{\\\"className\\\":\\\"mb-8 last:mb-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\\\",\\\"children\\\":7}],[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-gray-900\\\",\\\"children\\\":\\\"Swarm治理\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"Swarm需要治理：版本管理、升级策略、成本控制、合规审计。建议建立Swarm运维平台，提供可视化管理和操作界面。\\\"}]]}],\\\"$undefined\\\",\\\"$undefined\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"19:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"bg-gradient-to-r from-purple-50 to-violet-50 rounded-xl border border-purple-200 p-6 mt-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-purple-900 mb-4 flex items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"w-6 h-6 rounded bg-purple-100 te