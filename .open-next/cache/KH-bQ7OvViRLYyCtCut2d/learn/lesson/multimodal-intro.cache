,[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"开篇：超越文本的AI\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"传统AI主要处理文本，但真实世界是多感官的：图像、音频、视频、触觉……\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"多模态AI让机器像人类一样，同时理解和使用多种模态的信息。\"}]]}],\"$undefined\",\"$undefined\"]}],\"$L13\",\"$L14\",\"$L15\",\"$L16\",\"$L17\",\"$L18\"]}]}],\"$L19\",\"$L1a\",\"$undefined\"]}],\"$L1b\"]}]]}]\n13:[\"$\",\"div\",\"1\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":2}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"什么是多模态AI？\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**多模态（Multimodal）**指能够处理和理解多种类型数据（模态）的AI系统。\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**常见模态**：\\n- 文本：自然语言\\n- 图像：视觉信息\\n- 音频：声音和语音\\n- 视频：时序视觉\\n- 3D：空间信息\\n- 触觉：压力、温度等\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**多模态能力**：\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**输入理解**：\\n- 看图说话（图像→文本）\\n- 听音识别（音频→文本）\\n- 跨模态检索（文搜图）\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**输出生成**：\\n- 文生图（Text-to-Image）\\n- 文生视频（Text-to-Video）\\n- 文生音频（Text-to-Audio）\"}],[\"$\",\"p\",\"5\",{\"className\":\"whitespace-pre-line\",\"children\":\"**跨模态交互**：\\n- 图像问答（Image Q&A）\\n- 视觉对话\\n- 多模态推理\"}],[\"$\",\"p\",\"6\",{\"className\":\"whitespace-pre-line\",\"children\":\"**为什么重要？**\\n- 更丰富的交互体验\\n- 更准确的信息理解\\n- 更广的应用场景\"}]]}],\"$undefined\",[\"$\",\"div\",null,{\"className\":\"mt-4 p-4 bg-blue-50 rounded-lg border border-blue-200\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm text-blue-900 font-medium\",\"children\":[\"💡 \",\"多模态AI能理解、生成和交互多种类型的数据，突破单一模态的限制。\"]}]}]]}]\n14:[\"$\",\"div\",\"2\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":3}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"多模态模型架构\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**架构一：早期融合**\\n```\\n图像 → Encoder → ┐\\n                 ├→ 融合层 → Decoder → 输出\\n文本 → Encoder → ┘\\n```\\n特点：在特征层面早期融合，优点是模态交互充分，缺点是模态表示对齐困难。\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**架构二：晚期融合**\\n```\\n图像 → Encoder → 特征A → ┐\\n                           ├→ 融合层 → 输出\\n文本 → Encoder → 特征B → ┘\\n```\\n特点：在各模态独立编码后融合，优点是设计简单，缺点是跨模态交互受限。\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**架构三：交叉注意力（主流）**\\n```\\n文本编码 → ┐\\n           ├→ Cross-Attention → 输出\\n图像编码 → ┘\\n```\\n特点：通过注意力机制让模态间信息流动，如CLIP、GPT-4V、Gemini。\"}]]}],\"$undefined\",\"$undefined\"]}]\n15:[\"$\",\"div\",\"3\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":4}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"经典多模态模型\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**CLIP（Contrastive Language-Image Pre-training）**\\n- 模型：OpenAI\\n- 能力：文本-图像对齐，实现文搜图、图搜文\\n- 原理：对比学习，让文本和图像在共享空间对齐\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**GPT-4V（GPT-4 with Vision）**\\n- 模型：OpenAI\\n- 能力：理解图像，支持图像+文本输入\\n- 原理：视觉编码器+语言模型，交叉注意力融合\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Gemini（Google）**\\n- 模型：Google DeepMind\\n- 能力：文本、图像、音频、视频、代码多模态\\n- 原理：原生多模态架构，统一表示空间\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**DALL-E 3 / Midjourney**\\n- 模型：OpenAI / Midjourney\\n- 能力：文本生成高质量图像\\n- 原理：扩散模型，从噪声逐步生成图像\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**Whisper**\\n- 模型：OpenAI\\n- 能力：语音转文字\\n- 原理：Transformer编码器，端到端训练\"}]]}],\"$undefined\",\"$undefined\"]}]\n16:[\"$\",\"div\",\"4\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":5}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"代码示例：使用CLIP进行文搜图\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"用CLIP实现文本搜索图片：\"}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 bg-gray-900 rounded-lg overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\",\"children\":[\"$\",\"span\",null,{\"className\":\"text-sm text-gray-400 font-mono\",\"children\":\"python\"}]}],[\"$\",\"pre\",null,{\"className\":\"p-4 overflow-x-auto\",\"children\":[\"$\",\"code\",null,{\"className\":\"text-sm text-gray-100 font-mono whitespace-pre\",\"children\":\"import torch\\nfrom PIL import Image\\nimport clip\\nfrom tqdm import tqdm\\n\\n# 加载CLIP模型\\ndevice = \\\"cuda\\\" if torch.cuda.is_available() else \\\"cpu\\\"\\nmodel, preprocess = clip.load(\\\"ViT-B/32\\\", device=device)\\n\\n# 1. 编码查询文本\\ntext_query = \\\"a beautiful sunset over the ocean\\\"\\ntext_tokens = clip.tokenize([text_query]).to(device)\\n\\nwith torch.no_grad():\\n    text_features = model.encode_text(text_tokens)\\n    text_features = text_features / text_features.norm(dim=1, keepdim=True)\\n\\n# 2. 编码图片库（假设已提前编码）\\n# image_features = ...\\n\\n# 3. 计算相似度\\nsimilarity = (text_features @ image_features.T).squeeze(0)\\n\\n# 4. 排序返回最相似的图片\\nsorted_indices = similarity.argsort(descending=True)\\ntop_k = sorted_indices[:5]  # 返回Top-5\\n\\nprint(f\\\"最匹配的图片索引: {top_k.tolist()}\\\")\"}]}]]}],\"$undefined\"]}]\n17:[\"$\",\"div\",\"5\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":6}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"实战：多模态应用场景\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**场景一：智能客服**\\n- 用户上传截图描述问题\\n- 系统同时理解图片和文字\\n- 给出精准解决方案\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**场景二：教育辅助**\\n- 拍照识别题目\\n- 分析题目类型\\n- 提供解题思路\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**场景三：医疗影像**\\n- 上传X光片/CT\\n- AI结合图像和病历文本\\n- 辅助诊断建议\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**场景四：内容审核**\\n- 同时分析文本、图像、视频\\n- 多维度识别违规内容\\n- 降低误判率\"}]]}],\"$undefined\",\"$undefined\"]}]\n18:[\"$\",\"div\",\"6\",{\"className\