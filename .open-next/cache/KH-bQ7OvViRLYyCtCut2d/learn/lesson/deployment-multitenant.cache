"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"本节课讨论如何设计一个安全、高效的多租户系统。\"}]\n4:[\"$\",\"div\",\"1\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":2}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"多租户架构概述\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**什么是多租户？**\\n一个应用实例服务多个客户（租户），每个租户的数据和配置相互隔离。\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**三种隔离模型**：\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**1. 独立数据库**\\n- 每个租户一个数据库\\n- 隔离性最强\\n- 成本最高\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**2. 共享数据库，独立Schema**\\n- 共享数据库实例，每个租户一个Schema\\n- 隔离性中等\\n- 成本适中\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**3. 共享数据库，共享Schema**\\n- 通过租户ID区分数据\\n- 隔离性最弱\\n- 成本最低\"}],[\"$\",\"p\",\"5\",{\"className\":\"whitespace-pre-line\",\"children\":\"**选择依据**：\\n- 安全要求高的选独立数据库\\n- 成本敏感的选共享Schema\\n- 大部分SaaS选择共享Schema+租户ID\"}]]}],\"$undefined\",[\"$\",\"div\",null,{\"className\":\"mt-4 p-4 bg-blue-50 rounded-lg border border-blue-200\",\"children\":[\"$\",\"p\",null,{\"className\":\"text-sm text-blue-900 font-medium\",\"children\":[\"💡 \",\"多租户三种隔离模型：独立数据库、独立Schema、共享Schema，各有取舍。\"]}]}]]}]\n5:[\"$\",\"div\",\"2\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":3}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"数据隔离实现\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**共享Schema方案实现**：\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**1. 数据库层面**：\\n- 每个表添加tenant_id字段\\n- 创建复合索引：(tenant_id, id)\\n- 查询必须带tenant_id条件\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**2. 应用层面**：\\n- 请求上下文传递租户信息\\n- 中间件自动注入租户条件\\n- ORM层自动过滤\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**3. 安全层面**：\\n- API层验证租户身份\\n- 越权访问检测\\n- 数据导出审核\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**关键原则**：\\n- 永远不要相信客户端传的tenant_id\\n- 从认证Token中提取租户信息\\n- 所有查询必须带租户过滤\"}]]}],\"$undefined\",\"$undefined\"]}]\n6:[\"$\",\"div\",\"3\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":4}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"代码示例：多租户中间件\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"Express中间件自动注入租户过滤：\"}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 bg-gray-900 rounded-lg overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\",\"children\":[\"$\",\"span\",null,{\"className\":\"text-sm text-gray-400 font-mono\",\"children\":\"javascript\"}]}],[\"$\",\"pre\",null,{\"className\":\"p-4 overflow-x-auto\",\"children\":[\"$\",\"code\",null,{\"className\":\"text-sm text-gray-100 font-mono whitespace-pre\",\"children\":\"// 多租户中间件\\nfunction tenantMiddleware(req, res, next) {\\n  // 从JWT Token中获取租户ID（不信任客户端）\\n  const token = req.headers.authorization?.split(' ')[1];\\n  const decoded = verifyToken(token);\\n\\n  if (!decoded.tenantId) {\\n    return res.status(401).json({ error: 'Tenant not found' });\\n  }\\n\\n  // 注入到请求上下文\\n  req.tenantId = decoded.tenantId;\\n  next();\\n}\\n\\n// 数据库查询封装\\nclass TenantAwareRepository {\\n  constructor(model, tenantId) {\\n    this.model = model;\\n    this.tenantId = tenantId;\\n  }\\n\\n  async findAll(filter = {}) {\\n    // 自动添加租户过滤\\n    return this.model.findAll({\\n      where: {\\n        ...filter,\\n        tenantId: this.tenantId,  // 关键：自动注入\\n      },\\n    });\\n  }\\n\\n  async create(data) {\\n    // 自动添加租户ID\\n    return this.model.create({\\n      ...data,\\n      tenantId: this.tenantId,  // 关键：自动注入\\n    });\\n  }\\n}\\n\\n// 使用示例\\napp.get('/api/documents', tenantMiddleware, async (req, res) => {\\n  const repo = new TenantAwareRepository(Document, req.tenantId);\\n  const docs = await repo.findAll();\\n  res.json(docs);\\n});\"}]}]]}],\"$undefined\"]}]\n7:[\"$\",\"div\",\"4\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":5}],[\"$\",\"h3\",null,{\"className\":\"text-lg font-bold text-gray-900\",\"children\":\"资源配额管理\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[[\"$\",\"p\",\"0\",{\"className\":\"whitespace-pre-line\",\"children\":\"**为什么需要配额？**\\n防止单个租户占用过多资源，影响其他租户。\"}],[\"$\",\"p\",\"1\",{\"className\":\"whitespace-pre-line\",\"children\":\"**配额维度**：\"}],[\"$\",\"p\",\"2\",{\"className\":\"whitespace-pre-line\",\"children\":\"**1. 调用量限制**\\n- 每日/每月API调用次数\\n- 每分钟请求频率（Rate Limit）\\n- 并发请求限制\"}],[\"$\",\"p\",\"3\",{\"className\":\"whitespace-pre-line\",\"children\":\"**2. 数据量限制**\\n- 文档数量上限\\n- 向量存储容量\\n- 数据库存储空间\"}],[\"$\",\"p\",\"4\",{\"className\":\"whitespace-pre-line\",\"children\":\"**3. 功能限制**\\n- 可用模型（大模型额外付费）\\n- 高级功能（如自定义Agent）\\n- 导出数据量\"}],[\"$\",\"p\",\"5\",{\"className\":\"whitespace-pre-line\",\"children\":\"**实现方式**：\\n- Redis计数器：实时统计调用量\\n- 配置表：存储租户配额\\n- 中间件：配额检查和拒绝\"}]]}],\"$undefined\",\"$undefined\"]}]\nf:T4a0,import Redis from 'ioredis';\nconst redis = new Redis();\n\n// 配额检查中间件\nfunction quotaMiddleware(quotaConfig) {\n  return async (req, res, next) => {\n    const tenantId = req.tenantId;\n    const today = new Date().toISOString().split('T')[0];\n\n    // 1. 检查日配额\n    const dailyKey = `quota:${tenantId}:daily:${today}`;\n    const dailyCount = await redis.incr(dailyKey);\n    await redis.expire(dailyKey, 86400);  // 24小时过期\n\n    if (dailyCount > quotaConfig.dailyLimit) {\n      return res.status(429).json({\n        error: 'Daily quota exceeded',\n        limit: quotaConfig.dailyLimit,\n        used: dailyCount,\n      });\n    }\n\n    // 2. 检查频率限制（每分钟）\n    const minuteKey = `quota:${tenantId}:minute:${Date.now() / 60000 | 0}`;\n    const minuteCount = await redis.incr(minuteKey);\n    await redis.expire(minuteKey, 60);\n\n    if (minuteCount > quotaConfig.rateLimit) {\n      return res.status(429).json({\n        error: 'Rate limit exceeded',\n        limit: quotaConfig.rateLimit,\n      });\n    }\n\n    next();\n  };\n}\n\n// 使用\napp.get('/api/chat',\n  tenantMiddleware,\n  quotaMiddleware({ dailyLimit: 1000, rateLimit: 10 }),\n  chatHandler\n);8:[\"$\",\"div\",\"5\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\",\"children\":6}],[\"$\",\"h3\",null,{\"className\":\"text-