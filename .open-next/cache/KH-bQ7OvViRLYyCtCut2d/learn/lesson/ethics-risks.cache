\"$\\\",\\\"p\\\",\\\"1\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**1. 公平性（Fairness）**\\\\n- 避免基于种族、性别、年龄等的歧视\\\\n- 确保不同群体获得公平对待\\\\n- 定期检测和纠正偏见\\\"}],[\\\"$\\\",\\\"p\\\",\\\"2\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**2. 透明度（Transparency）**\\\\n- 向用户明确说明是AI生成的\\\\n- 公开模型的局限性\\\\n- 提供决策过程的可解释性\\\"}],[\\\"$\\\",\\\"p\\\",\\\"3\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**3. 隐私保护（Privacy）**\\\\n- 最小化数据收集\\\\n- 用户数据不被滥用\\\\n- 提供数据删除和退出选项\\\"}],[\\\"$\\\",\\\"p\\\",\\\"4\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**4. 可问责性（Accountability）**\\\\n- 明确责任归属\\\\n- 建立错误追责机制\\\\n- 提供人工复审和申诉渠道\\\"}]]}],\\\"$undefined\\\",[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-4 p-4 bg-blue-50 rounded-lg border border-blue-200\\\",\\\"children\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-sm text-blue-900 font-medium\\\",\\\"children\\\":[\\\"💡 \\\",\\\"AI伦理四大原则：公平性、透明度、隐私保护、可问责性。\\\"]}]}]]}]\\n14:[\\\"$\\\",\\\"div\\\",\\\"2\\\",{\\\"className\\\":\\\"mb-8 last:mb-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\\\",\\\"children\\\":3}],[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-gray-900\\\",\\\"children\\\":\\\"主要伦理风险\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**风险一：算法偏见**\\\\n- 训练数据中的社会偏见被模型学习\\\\n- 招聘、贷款、司法等场景的歧视\\\\n- 影响弱势群体权益\\\"}],[\\\"$\\\",\\\"p\\\",\\\"1\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**风险二：深度伪造**\\\\n- 生成虚假图像、音频、视频\\\\n- 用于诈骗、诽谤、政治操纵\\\\n- 破坏信任和社会稳定\\\"}],[\\\"$\\\",\\\"p\\\",\\\"2\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**风险三：隐私侵犯**\\\\n- 通过提示词诱导泄露个人信息\\\\n- 训练数据中的敏感信息泄露\\\\n- 面部识别、情感分析等监控滥用\\\"}],[\\\"$\\\",\\\"p\\\",\\\"3\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**风险四：错误信息传播**\\\\n- 生成看似合理但错误的内容\\\\n- \\\\\\\"幻觉\\\\\\\"问题影响决策\\\\n- 被用于制造虚假新闻\\\"}],[\\\"$\\\",\\\"p\\\",\\\"4\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"**风险五：人类能力退化**\\\\n- 过度依赖AI导致技能丧失\\\\n- 创造力、批判思维减弱\\\\n- 知识储备依赖外部\\\"}]]}],\\\"$undefined\\\",\\\"$undefined\\\"]}]\\n1c:T958,\"])</script><script>self.__next_f.push([1,\"from typing import List, Dict\\n\\nclass BiasDetector:\\n    \\\"\\\"\\\"偏见检测器\\\"\\\"\\\"\\n\\n    def __init__(self):\\n        # 敏感词汇列表\\n        self.sensitive_terms = {\\n            'gender': ['男人', '女人', '男性', '女性'],\\n            'age': ['年轻人', '老年人', '中年'],\\n            'race': ['黑人', '白人', '亚洲人']\\n        }\\n        # 负面情绪词\\n        self.negative_words = [\\n            '不行', '差', '有问题', '不适合', '不能'\\n        ]\\n\\n    def analyze_output(self, text: str, context: Dict) -\\u003e Dict:\\n        \\\"\\\"\\\"分析AI输出中的偏见\\\"\\\"\\\"\\n        results = {\\n            'has_bias': False,\\n            'bias_types': [],\\n            'evidence': []\\n        }\\n\\n        # 1. 检测敏感词+负面情绪的关联\\n        for category, terms in self.sensitive_terms.items():\\n            for term in terms:\\n                if term in text:\\n                    # 检查该敏感词附近是否有负面词\\n                    for neg_word in self.negative_words:\\n                        if neg_word in text:\\n                            results['has_bias'] = True\\n                            results['bias_types'].append(category)\\n                            results['evidence'].append({\\n                                'category': category,\\n                                'term': term,\\n                                'context': text[max(0, text.find(term)-20):text.find(term)+50]\\n                            })\\n\\n        # 2. 检测刻板印象关键词\\n        stereotypes = {\\n            '男性': ['强大', '理性', '领导'],\\n            '女性': ['温柔', '感性', '支持']\\n        }\\n        for group, traits in stereotypes.items():\\n            for trait in traits:\\n                if group in text and trait in text:\\n                    results['has_bias'] = True\\n                    results['bias_types'].append('stereotype')\\n                    results['evidence'].append(f\\\"潜在刻板印象：{group}-{trait}\\\")\\n\\n        return results\\n\\n# 使用示例\\ndetector = BiasDetector()\\noutput = \\\"这个岗位更适合男性，因为男性更理性、更有领导力\\\"\\nbias_report = detector.analyze_output(output, {})\\n\\nif bias_report['has_bias']:\\n    print(\\\"⚠️ 检测到潜在偏见！\\\")\\n    print(f\\\"偏见类型: {bias_report['bias_types']}\\\")\\n    print(f\\\"证据: {bias_report['evidence']}\\\")\\nelse:\\n    print(\\\"✓ 未检测到明显偏见\\\")\"])</script><script>self.__next_f.push([1,\"15:[\\\"$\\\",\\\"div\\\",\\\"3\\\",{\\\"className\\\":\\\"mb-8 last:mb-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm\\\",\\\"children\\\":4}],[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"text-lg font-bold text-gray-900\\\",\\\"children\\\":\\\"代码示例：偏见检测\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-gray-600 leading-relaxed space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"0\\\",{\\\"className\\\":\\\"whitespace-pre-line\\\",\\\"children\\\":\\\"检测AI输出中的潜在偏见：\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-4 bg-gray-900 rounded-lg overflow-hidden\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center justify-between px-4 py-2 bg-gray-800 border-b border-gray-700\\\",\\\"children\\\":[\\\"$\\\",\\\"s