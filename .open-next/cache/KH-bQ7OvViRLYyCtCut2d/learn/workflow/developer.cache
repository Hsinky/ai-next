[calc(100vh-56px)]\"><nav class=\"flex-1 overflow-y-auto p-4\"><div class=\"space-y-1\"><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/\"><span class=\"text-2xl\">🏠</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">首页</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">概览与推荐</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/skill\"><span class=\"text-2xl\">✨</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Skill</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">可复用的能力模块</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/mcp\"><span class=\"text-2xl\">🔌</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">MCP</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">外部工具与服务接入</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/agent\"><span class=\"text-2xl\">🤖</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Agent</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">自主决策的AI助手</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/prompt\"><span class=\"text-2xl\">📝</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Prompt</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">高效沟通的模板</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/workflow\"><span class=\"text-2xl\">🔄</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Workflow</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">多步骤任务编排</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/knowledge\"><span class=\"text-2xl\">🗃️</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Knowledge</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">企业知识智能检索</div></div></a></div></nav><div class=\"shrink-0 p-4 border-t border-gray-100 bg-white\"><div class=\"text-sm text-gray-400\"><div>版本 v1.0.0</div><div class=\"mt-1\">© 2026 AI Tools Center</div></div></div></aside><main class=\"flex-1 ml-72\"><div class=\"p-8\"><nav class=\"flex items-center gap-2 text-sm text-gray-500 mb-6\"><a class=\"hover:text-gray-700 transition-colors\" href=\"/learn\">学院</a><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg><a class=\"hover:text-gray-700 transition-colors\" href=\"/learn/path/developer\">开发者路径</a><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg><span class=\"text-gray-900 font-medium\">Workflow 编排</span></nav><div class=\"bg-gradient-to-r from-orange-500 to-amber-500 rounded-2xl p-8 text-white mb-8\"><div class=\"flex items-center gap-4 mb-4\"><span class=\"text-4xl\"></span><div><h1 class=\"text-2xl font-bold\">Workflow 编排</h1><p class=\"text-white/80\">高级 Workflow 编排</p></div></div><div class=\"flex items-center gap-6 text-white/80 text-sm\"><div class=\"flex items-center gap-2\"><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg><span>预计 <!-- -->90分钟</span></div><div class=\"flex items-center gap-2\"><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg><span>开发者路径</span></div></div></div><div class=\"bg-white rounded-xl border border-gray-200 p-4 mb-8\"><div class=\"flex items-center gap-2 text-sm\"><span class=\"text-gray-500\">难度选择：</span><a class=\"px-3 py-1.5 rounded-lg transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200\" href=\"/learn/workflow/beginner\">入门路径</a><a class=\"px-3 py-1.5 rounded-lg transition-colors bg-blue-600 text-white\" href=\"/learn/workflow/developer\">开发者路径</a><a class=\"px-3 py-1.5 rounded-lg transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200\" href=\"/learn/workflow/architect\">架构师路径</a></div></div><div class=\"bg-white rounded-xl border border-gray-200 p-8\"><div class=\"prose prose-gray max-w-none\"><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-orange-50 flex items-center justify-center text-sm\">1</span>控制流程详解</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-6\"><div class=\"space-y-4\"><div class=\"p-3 bg-purple-50 rounded-lg\"><h5 class=\"font-semibold mb-2\">条件分支（Conditional）</h5><div class=\"bg-gray-100 p-2 rounded font-mono text-xs\"><pre>if length(output) &gt; 500:\n    → 优化节点: {max_length: 300}\nelif length(output) &gt; 200:\n    → 轻微润色节点\nelse:\n    → 完善节点: {add_detail: true}</pre></div></div><div class=\"p-3 bg-orange-50 rounded-lg\"><h5 class=\"font-semibold mb-2\">循环（Loop）</h5><div class=\"bg-gray-100 p-2 rounded font-mono text-xs\"><pre># 固定次数\nfor item in items:\n    → 处理节点 {item: item}\n\n# 条件循环\nwhile not satisfied(result):\n    → 优化节点\n    max_iterations: 5</pre></div></div><div class=\"p-3 bg-blue-50 rounded-lg\"><h5 class=\"font-semibold mb-2\">并行执行（Parallel）</h5><div class=\"bg-gray-100 p-2 rounded font-mono text-xs\"><pre># 同时执行三个节点\nparallel:\n  - 翻译节点 {lang: &quot;en&quot;}\n  - 翻译节点 {lang: &quot;ja&quot;}\n  - 翻译节点 {lang: &quot;ko&quot;}\n\n# 等待全部完成后继续</pre></div><p class=\"text-xs text-gray-500 mt-1\">原本 15 秒 → 5 秒（假设每个 5 秒）</p></div><div class=\"p-3 bg-green-50 rounded-lg\"><h5 class=\"font-semibold mb-2\">子流程（Sub-Workflow）</h5><p class=\"text-sm text-gray-600\">将复杂工作流拆分为可复用的子流程，支持参数传递和返回</p></div></div></div></div></div><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-orange-50 flex items-center justify-center text-sm\">2</span>错误处理机制</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-4\"><div class=\"space-y-3\"><div class=\"p-3 bg-red-50 rounded-lg\"><h5 class=\"font-semibold mb-2 text-red-700\">Try-Catch 模式</h5><div class=\"bg-white p-2 rounded border text-xs\"><p>Try: 调用 Skill</p><p>Catch: 降级节点 {&quot;fallback&quot;: &quot;使用默认模板&quot;}</p><p>Finally: 日志记录</p></div></div><div class=\"p-3 bg-orange-50 rounded-lg\"><h5 class=\"font-semibold mb-2\">指数退避重试</h5><p class=\"text-sm text-gray-600 mb-2\">对临时性错误自动重试：</p><div class=\"text-xs text-gray-500\">首次：立即; 第2次：1秒后; 第3次：2秒后; 第4次：4秒后</div></div><div class=\"p-3 bg-yellow-50 rounded-lg\"><h5 class=\"font-semibold mb-2 text-yellow-800\">超时控制</h5><p class=\"text-sm text-gray-600\">为节点设置超时时间。超时后标记为失败，触发重试或降级</p></div><div class=\"p-3 bg-blue-50 rounded-lg\"><h5 class=\"font-semibold mb-2 text-blue-700\">失败通知</h5><p class=\"text-sm text-gray-600\">工作流失败时发送通知：邮件、Webhook、消息队列</p></div></div></div></div></div><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-orange-50 flex items-center justify-center text-sm\">3</span>变量与数据流</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-4\"><div class=\"bg-gray-50 p-4 rounded-lg\"><h4 class=\"font-semibold mb-3\">变量作用域</h4><div class=\"space-y-2\"><div class=\"flex items-start gap-2\"><span class=\"bg-blue-500 text-white px-2 py-1 rounded text-xs\">全局</span><div class=\"text-sm\"><p class=\"font-medium\">全局变量：user_id, company_id</p><p class=\"text-gray-500\">整个工作流共享</p></div></div><div class=\"flex items-start gap-2\"><span class=\"bg-green-500 text-white px-2 py-1 rounded text-xs\">分支</span><div class=\"text-sm\"><p class=\"font-medium\">分支变量：当前分支内有效</p></div></div><div class=\"flex items-start gap-2\"><span class=\"bg-purple-500 text-white px-2 py-1 rounded text-xs\">循环</span><div class=\"text-sm\"><p class=\"font-medium\">循环变量：index, current_item</p></div></div><div class=\"flex items-start gap-2\"><span class=\"bg-orange-500 text-white px-2 py-1 rounded text-xs\">临时</span><div class=\"text-sm\"><p class=\"font-medium\">节点间传递的临时数据</p></div></div></div></div><div class=\"bg-gray-100 p-3 rounded text-xs font-mono\"><pre># 节点间传递数据\nNode 1: {&quot;output&quot;: &quot;文本内容&quot;, &quot;len&quot;: 100}\nNode 2: 输入 = Node 1.output + &quot;（后缀）&quot;\nNode 3: 输入 = Node 2.len（引用节点1的len）</pre></div></div></div></div></div></div><div class=\"mt-8 flex items-center justify-between\"><a class=\"flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-4 py-2 rounded-lg hover:bg-gray-50\" href=\"/learn/path/developer\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"></path></svg>返回<!-- -->开发者路径</a><a class=\"flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-4 py-2 rounded-lg hover:bg-gray-50\" href=\"/learn\">返回学院<svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg></a></div></div><!--$--><!--/$--></main></div></div><script src=\"/_next/static/chunks/0j6kpnbwgrhei.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[30824,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"Providers\\\"]\\n3:I[87161,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"default\\\"]\\n4:I[40715,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"default\\\"]\\n5:I[78691,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\",\\\"/_next/static/chunks/0pe7_.ico216u.js\\\"],\\\"default\\\"]\\n6:I[30470,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\",\\\"/_next/static/chunks/0pe7_.ico216u.js\\\"],\\\"default\\\"]\\n8:I[98544,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"OutletBoundary\\\"]\\n9:\\\"$Sreact.suspense\\\"\\nc:I[98544,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"ViewportBoundary\\\"]\\ne:I[98544,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"MetadataBoundary\\\"]\\n10:I[92691,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/0.6dsdn7g3rv..css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/797e433ab948586e-s.p.0.q-h669a_dqa.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.16t1db8_9y2o~.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\