n: string,\\n  fn: () => Promise<T>\\n): Promise<T> {\\n  return tracer.startActiveSpan(operation, async (span) => {\\n    try {\\n      // 添加元数据\\n      span.setAttribute('model', 'gpt-4o');\\n      span.setAttribute('prompt_length', prompt.length);\\n\\n      const result = await fn();\\n\\n      // 记录结果\\n      span.setAttribute('success', true);\\n      span.setAttribute('tokens_used', result.usage.total_tokens);\\n\\n      return result;\\n    } catch (error) {\\n      span.recordException(error);\\n      span.setAttribute('success', false);\\n      throw error;\\n    } finally {\\n      span.end();\\n    }\\n  });\\n}\\n\\n// 使用示例\\nconst response = await withTracing(\\n  'openai.chat.completions',\\n  () => openai.chat.completions.create(...)\\n);\"}]}]]}]}]]}]\n17:[\"$\",\"div\",\"3\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"w-8 h-8 rounded-lg bg-cyan-50 flex items-center justify-center text-sm\",\"children\":4}],\"AI 安全与合规\"]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"p\",null,{\"children\":\"在企业环境中，AI 系统必须满足严格的安全和合规要求。\"}],[\"$\",\"h4\",null,{\"className\":\"font-semibold mt-4\",\"children\":\"安全防护层次\"}],[\"$\",\"div\",null,{\"className\":\"bg-gray-50 p-4 rounded-lg mt-4\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-3\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-start gap-3\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-red-500 text-white px-2 py-1 rounded text-xs font-bold\",\"children\":\"L1\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"font-semibold\",\"children\":\"输入过滤\"}],[\"$\",\"div\",null,{\"className\":\"text-sm\",\"children\":\"检测恶意输入、注入攻击、敏感信息\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"flex ite