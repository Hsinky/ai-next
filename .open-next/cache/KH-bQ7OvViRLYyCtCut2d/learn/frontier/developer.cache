e\",null,{\"children\":\"// 1. 准备训练数据（JSONL 格式）\\n{\\\"messages\\\": [\\n  {\\\"role\\\": \\\"system\\\", \\\"content\\\": \\\"你是客服助手\\\"},\\n  {\\\"role\\\": \\\"user\\\", \\\"content\\\": \\\"如何退款？\\\"},\\n  {\\\"role\\\": \\\"assistant\\\", \\\"content\\\": \\\"请在订单页面点击退款按钮...\\\"}\\n]}\\n\\n// 2. 上传训练文件\\nconst file = await openai.files.create({\\n  file: fs.createReadStream(\\\"training.jsonl\\\"),\\n  purpose: \\\"fine-tune\\\"\\n});\\n\\n// 3. 创建微调任务\\nconst job = await openai.fineTuning.jobs.create({\\n  training_file: file.id,\\n  model: \\\"gpt-3.5-turbo\\\"\\n});\\n\\n// 4. 等待完成并部署\\nconst fineTuned = await openai.fineTuning.jobs.retrieve(job.id);\\nconst model = fineTuned.fine_tuned_model; // \\\"ft:gpt-3.5-turbo:xxx\\\"\"}]}]]}]}]]}]\n7:[\"$\",\"div\",\"3\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"w-8 h-8 rounded-lg bg-cyan-50 flex items-center justify-center text-sm\",\"children\":4}],\"实时 AI 应用开发\"]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"p\",null,{\"children\":\"低延迟 API 和流式处理让实时 AI 应用成为可能。\"}],[\"$\",\"h4\",null,{\"className\":\"font-semibold mt-4\",\"children\":\"流式响应实现\"}],[\"$\",\"div\",null,{\"className\":\"bg-gray-900 text-green-400 p-4 rounded-lg font-mono text-sm overflow-x-auto\",\"children\":[\"$\",\"pre\",null,{\"children\":\"// Next.js 流式响应示例\\nexport async function POST(req: Request) {\\n  const { message } = await req.json();\\n\\n  const stream = await openai.chat.completions.create({\\n    model: \\\"gpt-4o\\\",\\n    messages: [{ role: \\\"user\\\", content: message }],\\n    stream: true  // 启用流式\\n  });\\n\\n  return new Response(\\n    new ReadableStream({\\n      async start(controller) {\\n        try {\\n          for await (const chunk of stream) {\\n            const content = chunk.choices[0]?.delta?.content || \\\"\\\";\\n            if (content) {\\n              controller.enqueue(\\n                new TextEncoder().encode(content)\\n              );\\n            }\\n          }\\n        } finally {\\n          controller.close();\\n        }\\n      }\\n    }),\\n    {\\n      headers: { \\\"Content-Type\\\": \\\"text/plain\\\" }\\n    }\\n  );\\n}\"}]}],[\"$\",\"h4\",null,{\"className\":\"font-semibold mt-4\",\"children\":\"实时场景\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-6 space-y-2\",\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"实时翻译\"}],\": 会议即时翻译字幕\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"代码助手\"}],\": 边写边补全代码\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"智能客服\"}],\": 实时对话交互\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"语音交互\"}],\": 即时语音反馈\"]}]]}]]}]}]]}]\n8:[\"$\",\"div\",\"4\",{\"className\":\"mb-8 last:mb-0\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"w-8 h-8 rounded-lg bg-cyan-50 flex items-center justify-center text-sm\",\"children\":5}],\"API 安全最佳实践\"]}],[\"$\",\"div\",null,{\"className\":\"text-gray-600 leading-relaxed space-y-4\",\"children\":[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"p\",null,{\"children\":\"保护 API 密钥和数据安全是生产环境的首要任务。\"}],[\"$\",\"h4\",null,{\"className\":\"font-semibold mt-4\",\"children\":\"安全实践清单\"}],[\"$\",\"div\",null,{\"className\":\"bg-red-50 p-4 rounded-lg\",\"children\":[[\"$\",\"h5\",null,{\"className\":\"font-semibold mb-2\",\"children\":\"🔒 必须做\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 space-y-1 text-sm\",\"children\":[[\"$\",\"li\",null,{\"children\":\"API 密钥存储在环境变量，不提交到代码库\"}],[\"$\",\"li\",null,{\"children\":\"使用 .env 文件和 .gitignore\"}],[\"$\",\"li\",null,{\"children\":\"在前端调用 API 时使用后端代理\"}],[\"$\",\"li\",null,{\"children\":\"启用 API 调用速率限制\"}],[\"$\",\"li\",null,{\"children\":\"记录和监控 API 使用情况\"}],[\"$\",\"li\",null,{\"children\":\"实施用户认证和授权\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"bg-gray-900 text-green-400 p-4 rounded-lg font-mono text-sm overflow-x-auto\",\"children\":[\"$\",\"pre\",null,{\"children\":\"// 后端代理示例（保护 API Key）\\n// api/chat/route.ts\\nimport { NextRequest, NextResponse } from 'next/server';\\n\\nexport async function POST(req: NextRequest) {\\n  // 1. 验证用户权限\\n  const user = await authenticate(req);\\n  if (!user) {\\n    return NextResponse.json({ error: \\\"Unauthorized\\\" },\\n      { status: 401 });\\n  }\\n\\n  // 2. 检查速率限制\\n  const rateLimited = await checkRateLimit(user.id);\\n  if (rateLimited) {\\n    return NextResponse.json({ error: \\\"Too many requests\\\" },\\n      { status: 429 });\\n  }\\n\\n  // 3. 调用 OpenAI API（密钥在服务器端）\\n  const response = await openai.chat.completions.create({\\n    model: \\\"gpt-4o\\\",\\n    messages: await req.json().then(d => d.messages)\\n  });\\n\\n  return NextResponse.json(response.choices[0].message);\\n}\"}]}]]}]}]]}]\n9:[\"$\",\"div\",null,{\"className\":\"mt-8 flex items-center justify-between\",\"children\":[[\"$\",\"$L2\",null,{\"href\":\"/learn/path/developer\",\"className\":\"flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-4 py-2 rounded-lg hover:bg-gray-50\",\"children\":[[\"$\",\"svg\",null,{\"className\":\"w-5 h-5\",\"fill\":\"none\",\"stroke\":\"currentColor\",\"viewBox\":\"0 0 24 24\",\"children\":[\"$\",\"path\",null,{\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"strokeWidth\":2,\"d\":\"M15 19l-7-7 7-7\"}]}],\"返回\",\"开发者路径\"]}],[\"$\",\"$L2\",null,{\"href\":\"/learn\",\"className\":\"flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-4 py-2 rounded-lg hover:bg-gray-50\",\"children\":[\"返回学院\",[\"$\",\"svg\",null,{\"className\":\"w-5 h-5\",\"fill\":\"none