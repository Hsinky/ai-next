{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/(main)/layout,_N_T_/(main)/learn/layout,_N_T_/(main)/learn/[type]/layout,_N_T_/(main)/learn/[type]/[level]/layout,_N_T_/(main)/learn/[type]/[level]/page,_N_T_/learn/prompt/beginner"},"segmentPaths":["/_tree","/_full","/!KG1haW4p/learn/$d$type/$d$level/__PAGE__","/!KG1haW4p/learn/$d$type/$d$level","/!KG1haW4p/learn/$d$type","/!KG1haW4p/learn","/!KG1haW4p","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0.q-h669a_dqa.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.16t1db8_9y2o~.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0.6dsdn7g3rv..css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0j6kpnbwgrhei.js\"/><script src=\"/_next/static/chunks/14uv9l3-k2qh4.js\" async=\"\"></script><script src=\"/_next/static/chunks/16sk4~vc8e6sh.js\" async=\"\"></script><script src=\"/_next/static/chunks/0c9ih0_ge37cg.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-02v2juswviadt.js\" async=\"\"></script><script src=\"/_next/static/chunks/0~gz256ffq795.js\" async=\"\"></script><script src=\"/_next/static/chunks/0pk5qoo78d3co.js\" async=\"\"></script><script src=\"/_next/static/chunks/0pe7_.ico216u.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Prompt 工程入门教程 - AI工具市场</title><meta name=\"description\" content=\"学习 Prompt 工程 的入门知识\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen bg-gray-50\"><header class=\"bg-white border-b border-gray-200 sticky top-0 z-50\"><div class=\"flex items-center justify-between px-6 py-3\"><a class=\"flex items-center gap-3 hover:opacity-80 transition-opacity\" href=\"/\"><div class=\"w-8 h-8 bg-linear-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center\"><span class=\"text-white text-sm\">⚡</span></div><div class=\"flex flex-col\"><span class=\"text-xl font-bold bg-linear-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent\">AI 工具市场</span></div></a><div class=\"flex items-center gap-4\"><div class=\"relative w-72\"><div class=\"relative\"><svg class=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"></path></svg><input type=\"text\" placeholder=\"全局搜索...\" class=\"w-full pl-9 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all\" value=\"\"/></div></div><a class=\"w-10 h-10 rounded-full bg-gray-100 hover:bg-blue-100 flex items-center justify-center text-lg transition-colors group\" title=\"学院\" href=\"/learn\"><span class=\"group-hover:scale-110 transition-transform\">🎓</span></a><a href=\"http://hsinky.cn\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"w-10 h-10 rounded-full bg-gray-100 hover:bg-purple-100 flex items-center justify-center text-lg transition-colors group\" title=\"个人博客\"><span class=\"group-hover:scale-110 transition-transform\">📰</span></a></div></div></header><div class=\"flex\"><aside class=\"w-72 bg-white border-r border-gray-200 flex flex-col fixed left-0 top-14 h-[calc(100vh-56px)]\"><nav class=\"flex-1 overflow-y-auto p-4\"><div class=\"space-y-1\"><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/\"><span class=\"text-2xl\">🏠</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">首页</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">概览与推荐</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/skill\"><span class=\"text-2xl\">✨</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Skill</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">可复用的能力模块</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/mcp\"><span class=\"text-2xl\">🔌</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">MCP</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">外部工具与服务接入</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/agent\"><span class=\"text-2xl\">🤖</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Agent</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">自主决策的AI助手</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/prompt\"><span class=\"text-2xl\">📝</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Prompt</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">高效沟通的模板</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/workflow\"><span class=\"text-2xl\">🔄</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Workflow</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">多步骤任务编排</div></div></a><a class=\"group flex items-center gap-4 px-4 py-4 rounded-xl transition-all duration-200 text-gray-600 hover:bg-gray-50\" href=\"/knowledge\"><span class=\"text-2xl\">🗃️</span><div class=\"flex-1 min-w-0\"><div class=\"font-medium text-gray-700 group-hover:text-gray-900\">Knowledge</div><div class=\"text-sm text-gray-400 truncate mt-0.5\">企业知识智能检索</div></div></a></div></nav><div class=\"shrink-0 p-4 border-t border-gray-100 bg-white\"><div class=\"text-sm text-gray-400\"><div>版本 v1.0.0</div><div class=\"mt-1\">© 2026 AI Tools Center</div></div></div></aside><main class=\"flex-1 ml-72\"><div class=\"p-8\"><nav class=\"flex items-center gap-2 text-sm text-gray-500 mb-6\"><a class=\"hover:text-gray-700 transition-colors\" href=\"/learn\">学院</a><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg><a class=\"hover:text-gray-700 transition-colors\" href=\"/learn/path/beginner\">入门路径</a><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg><span class=\"text-gray-900 font-medium\">Prompt 工程</span></nav><div class=\"bg-gradient-to-r from-blue-500 to-cyan-500 rounded-2xl p-8 text-white mb-8\"><div class=\"flex items-center gap-4 mb-4\"><span class=\"text-4xl\"></span><div><h1 class=\"text-2xl font-bold\">Prompt 工程</h1><p class=\"text-white/80\">掌握与 AI 沟通的艺术</p></div></div><div class=\"flex items-center gap-6 text-white/80 text-sm\"><div class=\"flex items-center gap-2\"><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg><span>预计 <!-- -->75分钟</span></div><div class=\"flex items-center gap-2\"><svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg><span>入门路径</span></div></div></div><div class=\"bg-white rounded-xl border border-gray-200 p-4 mb-8\"><div class=\"flex items-center gap-2 text-sm\"><span class=\"text-gray-500\">难度选择：</span><a class=\"px-3 py-1.5 rounded-lg transition-colors bg-blue-600 text-white\" href=\"/learn/prompt/beginner\">入门路径</a><a class=\"px-3 py-1.5 rounded-lg transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200\" href=\"/learn/prompt/developer\">开发者路径</a><a class=\"px-3 py-1.5 rounded-lg transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200\" href=\"/learn/prompt/architect\">架构师路径</a></div></div><div class=\"bg-white rounded-xl border border-gray-200 p-8\"><div class=\"prose prose-gray max-w-none\"><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-sm\">1</span>第一课：Prompt 的本质</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-6\"><div class=\"bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-lg\"><h3 class=\"font-bold text-lg mb-2\">核心洞察</h3><p class=\"text-gray-700\"><strong>Prompt 是你给 AI 的&quot;上下文&quot;。</strong>模型根据这个上下文预测它认为最合适的回答。</p></div><div class=\"space-y-4\"><h4 class=\"font-bold text-lg\">关键认知：模型&quot;看到&quot;的就是你&quot;写&quot;的</h4><div class=\"bg-gray-50 p-4 rounded-lg\"><p class=\"text-gray-600 mb-3\">当你发送 Prompt 时，模型看到的是一串 Token。它不知道你的意图，只能根据这些 Token 进行概率预测。</p><div class=\"bg-purple-50 p-3 rounded\"><p class=\"text-sm font-medium mb-2\">关键启示</p><ul class=\"text-sm text-gray-600 space-y-1\"><li>• 假设模型什么都不懂，把一切写清楚</li><li>• 提供示例比描述规则更有效</li><li>• 清晰的结构帮助模型理解</li></ul></div></div></div><div class=\"space-y-4\"><h4 class=\"font-bold text-lg\">好 Prompt vs 坏 Prompt</h4><div class=\"grid grid-cols-2 gap-4\"><div class=\"bg-red-50 p-4 rounded-lg border-2 border-red-200\"><h5 class=\"font-semibold mb-2 text-red-700\">坏 Prompt</h5><div class=\"bg-gray-100 p-3 rounded font-mono text-sm mb-2\">&quot;写个方案&quot;</div><ul class=\"text-xs text-gray-600 space-y-1\"><li>❌ 没有具体要求</li><li>❌ 没有上下文说明</li><li>❌ 没有输出格式</li><li>❌ 结果：泛泛而谈，不符合实际需求</li></ul></div><div class=\"bg-green-50 p-4 rounded-lg border-2 border-green-200\"><h5 class=\"font-semibold mb-2 text-green-700\">好 Prompt</h5><div class=\"bg-gray-100 p-3 rounded font-mono text-sm mb-2 overflow-hidden\">&quot;你是产品经理，写一个电商App的注册流程优化方案。目标：将注册转化率提升20%。输出要求：问题分析、优化方案、预期效果、实施步骤。&quot;</div><ul class=\"text-xs text-gray-600 space-y-1\"><li>✅ 明确角色和目标</li><li>✅ 上下文清晰</li><li>✅ 详细的输出要求</li><li>✅ 结果：直接可用的方案</li></ul></div></div></div></div></div></div><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-sm\">2</span>第二课：Prompt 的黄金结构</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-6\"><h4 class=\"font-bold text-lg mb-3\">一个完整的 Prompt 应该包含这些部分：</h4><div class=\"bg-gray-100 p-4 rounded-lg\"><div class=\"font-mono text-sm space-y-2\"><div><span class=\"text-blue-600 font-bold\">1. 角色定义</span> - 你希望 AI 扮演什么角色</div><div><span class=\"text-green-600 font-bold\">2. 背景信息</span> - 当前任务的相关背景</div><div><span class=\"text-purple-600 font-bold\">3. 任务目标</span> - 明确要达成的目标</div><div><span class=\"text-orange-600 font-bold\">4. 输入内容</span> - 需要处理的内容</div><div><span class=\"text-red-600 font-bold\">5. 输出要求</span> - 期望的格式和标准</div><div><span class=\"text-gray-600 font-bold\">6. 约束条件</span> - 限制和边界</div><div><span class=\"text-cyan-600 font-bold\">7. 示例</span> - 输入输出示例（可选但推荐）</div></div></div><div class=\"bg-blue-50 p-4 rounded-lg\"><h4 class=\"font-bold mb-3 text-blue-700\">实战示例：让 AI 改写邮件</h4><div class=\"bg-white p-4 rounded border font-mono text-sm\"><pre>【角色定义】你是一个专业的邮件撰写专家，擅长将信息重组为结构清晰的商务邮件。\n\n【背景信息】我需要回复一个客户，说明项目进度延迟，提出补救方案。\n\n【任务目标】撰写一封专业、诚恳的回复邮件。\n\n【原始邮件内容】\n客户询问：为什么项目延期了？什么时候能交付？\n\n【项目当前状态】\n- 原定交付日期：2024年3月15日\n- 原因：需求变更导致额外开发工作\n- 新交付日期：2024年4月1日\n- 补救：延长一个月售后支持\n\n【输出要求】\n1. 邮件主题：专业且清晰\n2. 正文：分为项目进度说明、延期原因、补救措施三个部分\n3. 语气：诚恳、专业，表达歉意\n4. 长度：200-300字\n\n【约束条件】\n- 不使用过于技术化的术语\n- 重点放在补救措施上\n- 避免过多解释细节\n\n【示例】（参考以下邮件风格）\n尊敬的[姓名]，\n\n您好！关于您关心的[项目名称]，我们在此向您汇报最新进展...\n\n[正文]\n\n再次感谢您的理解！\n[你的名字]</pre></div></div></div></div></div><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-sm\">3</span>第三课：Prompt 实用技巧 - 从入门到精通</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-6\"><div class=\"space-y-4\"><h4 class=\"font-bold text-lg\">技巧 1：具体化（Be Specific）</h4><div class=\"bg-gray-50 p-4 rounded-lg\"><div class=\"grid grid-cols-2 gap-3 text-sm\"><div class=\"bg-green-50 p-3 rounded\"><p class=\"font-semibold text-green-700 mb-2\">更清晰</p><p>&quot;写一个200字公司简介，突出技术创新和团队优势，使用专业但不过于学术的语气&quot;</p></div><div class=\"bg-red-50 p-3 rounded\"><p class=\"font-semibold text-red-700 mb-2\">太模糊</p><p>&quot;写个简介&quot;</p></div></div><p class=\"text-xs text-gray-500 mt-2\">关键：指定长度、重点、语气三个维度</p></div></div><div class=\"space-y-4\"><h4 class=\"font-bold text-lg\">技巧 2：分步骤（Step by Step）</h4><div class=\"bg-purple-50 p-4 rounded-lg\"><p class=\"text-gray-700 mb-3\">要求模型&quot;一步步思考&quot;，展示推理过程：</p><div class=\"bg-white p-3 rounded border text-sm\"><p>&quot;为了准确解决这个问题，请：</p><p class=\"pl-4\">1. 分析问题的关键要素</p><p class=\"pl-4\">2. 列出可能的解决方案</p><p class=\"pl-4\">3. 比较各方案的优缺点</p><p class=\"pl-4\">4. 给出最终建议</p><p>请一步步思考并输出。&quot;</p></div></div></div><div class=\"space-y-4\"><h4 class=\"font-bold text-lg\">技巧 3：提供示例（Few-Shot）</h4><div class=\"bg-green-50 p-4 rounded-lg\"><p class=\"text-gray-700 mb-3\">给模型 1-3 个示例，让它模仿风格和格式：</p><div class=\"bg-white p-3 rounded border text-sm space-y-2\"><p><strong>示例 1：</strong></p><p>输入：&quot;我最近总是觉得疲惫&quot;</p><p>输出：&quot;你提到的疲惫感，最近有什么特别的变化吗？比如睡眠情况或工作压力？&quot;</p><p class=\"mt-2\"><strong>示例 2：</strong></p><p>输入：&quot;我对未来很迷茫&quot;</p><p>输出：&quot;迷茫是很正常的感受，你现在是遇到了什么具体的选择吗？&quot;</p><p class=\"mt-2\"><strong>你的输入：</strong></p><p>&quot;我不知道该怎么和父母沟通&quot;</p><p><strong>请模仿示例风格回答：</strong></p></div></div></div><div class=\"space-y-4\"><h4 class=\"font-bold text-lg\">技巧 4：思维链（Chain of Thought）</h4><div class=\"bg-orange-50 p-4 rounded-lg\"><p class=\"text-gray-700 mb-3\">对复杂问题，要求模型展示思考过程：</p><div class=\"bg-white p-3 rounded border text-sm\"><p>&quot;23 * 45 = ?</p><p>请一步步计算：</p><p>第一，将23分解为(20 + 3)</p><p>第二，计算20 * 45 = 900</p><p>第三，计算3 * 45 = 135</p><p>第四，相加：900 + 135 = 1035</p><p>所以答案是：1035&quot;</p></div><p class=\"text-xs text-gray-500 mt-2\">适用场景：数学计算、逻辑推理、代码调试等需要步骤的问题</p></div></div></div></div></div><div class=\"mb-8 last:mb-0\"><h2 class=\"text-xl font-bold text-gray-900 mb-4 flex items-center gap-2\"><span class=\"w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-sm\">4</span>第四课：常见陷阱与规避</h2><div class=\"text-gray-600 leading-relaxed space-y-4\"><div class=\"space-y-6\"><h4 class=\"font-bold text-lg mb-3\">这 10 个错误，90% 的人都犯过：</h4><div class=\"space-y-3\"><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">1. 命令式语气</p><p class=\"text-sm text-gray-600\">错误：&quot;给我写个...&quot; / 正确：&quot;请你帮忙写一个...&quot;（礼貌性影响模型态度）</p></div><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">2. 信息不足</p><p class=\"text-sm text-gray-600\">错误：不说清楚背景、目标、受众 / 正确：提供完整的上下文和约束条件</p></div><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">3. 结构混乱</p><p class=\"text-sm text-gray-600\">错误：一大段不分行的文字 / 正确：使用标题、列表、分段组织内容</p></div><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">4. 空洞的角色定义</p><p class=\"text-sm text-gray-600\">错误：&quot;你是专家&quot; / 正确：&quot;你是拥有5年经验的产品经理&quot;</p></div><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">5. 期望模型理解隐喻</p><p class=\"text-sm text-gray-600\">错误：&quot;像老朋友那样聊天&quot; / 正确：明确要求使用口语化表达，可以适当使用表情符号</p></div><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">6. 不设定输出长度</p><p class=\"text-sm text-gray-600\">结果：模型可能生成超长内容浪费 Token，或过于简短信息不足</p></div><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">7. 混合多个目标</p><p class=\"text-sm text-gray-600\">一个 Prompt 只做一件事，复杂任务拆分或使用 Chain</p></div><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">8. 不测试 Prompt</p><p class=\"text-sm text-gray-600\">同一个 Prompt 输入不同内容测试，观察输出一致性</p></div><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">9. Temperature 设置不当</p><p class=\"text-sm text-gray-600\">确定性任务用 0-0.3，创意任务用 0.7-1.0</p></div><div class=\"p-3 bg-red-50 rounded-lg border-l-4 border-red-500\"><p class=\"font-semibold mb-1\">10. 不使用结构化输出</p><p class=\"text-sm text-gray-600\">总是要求 JSON、列表等结构化格式，便于程序解析和理解</p></div></div></div></div></div></div></div><div class=\"mt-8 flex items-center justify-between\"><a class=\"flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-4 py-2 rounded-lg hover:bg-gray-50\" href=\"/learn/path/beginner\"><svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 19l-7-7 7-7\"></path></svg>返回<!-- -->入门路径</a><a class=\"flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-4 py-2 rounded-lg hover:bg-gray-50\" href=\"/learn\">返回学院<svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg></a></div></div><!--$--><!--/$--></main></div></div><script src=\"/_next/static/chunks/0j6kpnbwgrhei.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[30824,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"Providers\\\"]\\n3:I[87161,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"default\\\"]\\n4:I[40715,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"default\\\"]\\n5:I[78691,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\",\\\"/_next/static/chunks/0pe7_.ico216u.js\\\"],\\\"default\\\"]\\n6:I[30470,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\",\\\"/_next/static/chunks/0pe7_.ico216u.js\\\"],\\\"default\\\"]\\n8:I[98544,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"OutletBoundary\\\"]\\n9:\\\"$Sreact.suspense\\\"\\nc:I[98544,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"ViewportBoundary\\\"]\\ne:I[98544,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"MetadataBoundary\\\"]\\n10:I[92691,[\\\"/_next/static/chunks/0~gz256ffq795.js\\\",\\\"/_next/static/chunks/0pk5qoo78d3co.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/0.6dsdn7g3rv..css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/797e433ab948586e-s.p.0.q-h669a_dqa.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.16t1db8_9y2o~.woff2\\\",\\\"font\\\",{\\\"crossOr