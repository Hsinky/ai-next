{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-next",
  "compatibility_date": "2026-05-07",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "observability": { "enabled": true },
  "build": {
    "command": "npx @opennextjs/cloudflare build"
  }
}
